\",\"targetPort\":\"{#}4M2WbT3_input_agent\"}],\"state\":{\"description\":\"Provides a simple in-memory history manager for debugging purposes.\",\"inputs\":[{\"index\":0,\"label\":\"agent\",\"name\":\"input1\",\"type\":[5],\"position\":{\"x\":519,\"y\":291}}],\"outputs\":[],\"name\":\"Memory History\",\"type\":\"custom\",\"color\":\"#eac43e\",\"icon\":\"database\",\"canvasPosition\":{\"x\":0,\"y\":0},\"markdownHelp\":\"\",\"settings\":[],\"protocolVersion\":\"2\"},\"type\":\"widgetGroup\"},\"{#}4M2WbT3\":{\"id\":\"{#}4M2WbT3\",\"canvas\":{\"position\":{\"x\":659,\"y\":341}},\"children\":[{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_getHistory\",\"targetPort\":\"{#}jCnteeA_input_read\"},{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_updateHistory\",\"targetPort\":\"{#}jCnteeA_input_update\"}],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{\"includeAttachments\":false,\"timeout\":60},\"variantId\":\"history\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"in