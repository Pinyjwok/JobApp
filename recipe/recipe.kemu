20.398 223.2-223.2 223.2-585.6 1.1992-808.8z\"/>\n <path d=\"m739.2 1028.4-22.801 7.1992c-32.398 8.3984-51.602 42-43.199 75.602 7.1992 27.602 32.398 45.602 58.801 45.602 4.8008 0 10.801-1.1992 15.602-2.3984 9.6016-2.3984 19.199-6 28.801-8.3984 32.398-10.801 49.199-45.602 38.398-76.801-8.4023-33.602-43.199-51.602-75.602-40.805z\"/>\n <path d=\"m532.8 1046.4-24-3.6016c-33.602-7.1992-66 14.398-72 48-7.1992 33.602 14.398 66 48 72 9.6016 2.3984 20.398 3.6016 30 4.8008 2.3984 0 6 1.1992 9.6016 1.1992 30 0 56.398-21.602 60-52.801 4.7969-33.598-18.004-64.797-51.602-69.598z\"/>\n <path d=\"m321.6 955.2c-26.398-20.398-64.801-16.801-86.398 9.6016-20.398 26.398-16.801 64.801 9.6016 86.398 8.3984 6 15.602 12 24 18 10.801 7.1992 22.801 10.801 34.801 10.801 19.199 0 38.398-8.3984 50.398-26.398 19.199-27.602 13.199-66-14.398-85.199z\"/>\n <path d=\"m192 793.2c-14.398-31.199-50.398-44.398-81.602-30-31.199 14.398-44.398 50.398-30 81.602 4.8008 9.6016 8.3984 18 13.199 27.602 10.801 20.398 32.398 32.398 54 32.398 9.6016 0 19.199-2.3984 28.801-7.1992 30-15.602 40.801-52.801 25.199-82.801z\"/>\n <path d=\"m800.4 657.6-140.4-90v-223.2c0-33.602-27.602-61.199-61.199-61.199-33.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n","inputs":[{"name":"agent","description":"Connect to the agent","type":5}],"outputs":[{"name":"getHistory","description":"Invoked when the agent needs to retrieve the conversation history","type":5},{"name":"updateHistory","description":"Invoked when the agent needs to update the conversation history","type":5}],"color":"#eac43e"}],"publicationId":"kemu.io.ai-agent-osx-arm64-1.8.2","sessionId":1777586144,"internal":false}},"type":"hubService","secrets":{"OPENROUTER_API_KEY":{"name":"OPENROUTER_API_KEY","sharedAcrossInstances":true,"hubServiceName":"kemu.io.ai-agent"}},"groupId":"{#}oIeMupm"},"{#}8vG2tgX":{"id":"{#}8vG2tgX","canvas":{"position":{"x":760,"y":582}},"children":[{"childId":"{#}CWXSdDf","sourcePort":"{#}8vG2tgX_output_sessionHistoryOutput","targetPort":"{#}CWXSdDf_input_input"}],"state":{"pauseExecution":false,"autoPauseOnError":true,"version":2,"metadata":{"name":"Memory History","description":"Keeps the history messages in memory (this is intended for dev purposes only)"},"pages":{"main":{"code":"/**\n * Name: Memory History\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\n */\n\nconst sessions = {};\n\nconst getWidgetInputs = () => [\n  { name: 'read', type: DataType.JsonObj },\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\n];\n\nconst getWidgetOutputs = () => [\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\n];\n\nconst onParentEvent = async ({ targetPort, event }) => {\n  const inputData = event.data.value;\n\n  if (targetPort.name === 'read') {\n    const sessionId = inputData.sessionId;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'read' event missing 'sessionId' property.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\n\n  } else if (targetPort.name === 'update') {\n    const sessionId = inputData.sessionId;\n    const messagesToProcess = inputData.messages;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'update' event missing 'sessionId' property.\");\n      return;\n    }\n    if (messagesToProcess === undefined || messagesToProcess === null) {\n      console.error(\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    if (Array.isArray(messagesToProcess)) {\n      sessions[sessionId].messages.push(...messagesToProcess);\n    } else {\n      sessions[sessionId].messages.push(messagesToProcess);\n    }\n  }\n};","language":"javascript","name":"My First Script"}}},"type":"script","secrets":{},"groupId":"{#}oIeMupm"},"{#}Q56Ivhy":{"id":"{#}Q56Ivhy","canvas":{"position":{"x":512,"y":198}},"children":[],"state":{"text":"# Agent Memory\n\nBasic in-memory history that allows the agent to remember chat history. This is a basic solution (make sure you instruct your agents to read and write a “memory” file using their available tools to persist progress to disk).\n","color":"#a9b8c2","size":{"width":917,"height":200},"locked":true},"type":"note","groupId":"{#}oIeMupm"},"{#}4nBrZwl":{"id":"{#}4nBrZwl","canvas":{"position":{"x":1621,"y":1004}},"children":[{"childId":"{#}mfjvXBd","sourcePort":"{#}4nBrZwl_output_tools","targetPort":"{#}mfjvXBd_input_outer-input-input1"},{"childId":"{#}Pc3AXUh","sourcePort":"{#}4nBrZwl_output_history","targetPort":"{#}Pc3AXUh_input_outer-input-input1"},{"childId":"{#}6Q9yktY","sourcePort":"{#}4nBrZwl_output_reasoning","targetPort":"{#}6Q9yktY_input_setValue"},{"childId":"{#}LAiTPla","sourcePort":"{#}4nBrZwl_output_debug","targetPort":"{#}LAiTPla_input_setValue"},{"childId":"{#}rL3kMjn","sourcePort":"{#}4nBrZwl_output_text","targetPort":"{#}rL3kMjn_input_setValue"},{"childId":"{#}6854yne","sourcePort":"{#}4nBrZwl_output_text","targetPort":"{#}6854yne_input_event"}],"state":{"dynamicInputs":{},"dynamicOutputs":{},"customState":{"selectedModel":{"id":"google/gemini-3-flash-preview","slug":"google/gemini-3-flash-preview-20251217","name":"Google: Gemini 3 Flash Preview","description":"Gemini 3 Flash Preview is a high speed, high value thinking model designed for agentic workflows, multi turn chat, and coding assistance. It delivers near Pro level reasoning and tool use performance with substantially lower latency than larger Gemini variants, making it well suited for interactive development, long running agent loops, and collaborative coding tasks. Compared to Gemini 2.5 Flash, it provides broad quality improvements across reasoning, multimodal understanding, and reliability.\n\nThe model supports a 1M token context window and multimodal inputs including text, images, audio, video, and PDFs, with text output. It includes configurable reasoning via thinking levels (minimal, low, medium, high), structured output, tool use, and automatic context caching. Gemini 3 Flash Preview is optimized for users who want strong reasoning and agentic behavior without the cost or latency of full scale frontier models.","inputModalities":["text","image","file","audio","video"],"outputModalities":["text"],"supportsTools":true,"supportsReasoning":true,"promptPrice":5e-7,"completionPrice":0.000003,"maxTokens":65536,"contextLength":1048576,"provider":"google"},"systemInstructions":"# Skills Curator v1.7 — System Instructions\n\n**Version:** 1.8\n**Last Updated:** 2026-04-22\n**Role:** Skills Section Organizer\n**Pipeline Position:** Assembly Phase 3 (parallel with PB/HF/CF/CLW)\n**Trigger:** Dispatched in parallel after Style Negotiation\n**Output:** Writes `sc_output.json` (server merges into phases[2] at join)\n\n---\n\n## Role\n\nYou organize the skills section by:\n1. Prioritizing skills from gap_analysis.strengths\n2. Categorizing into Technical, Soft Skills, Certifications\n3. Applying ATS keyword optimization\n4. Formatting as concise bullets\n\n---\n\n## Authority\n\n### READ Access\n- `candidate_profile.json`\n- `project_memory.json`\n- `cv_assembly_state.json`\n\n### WRITE Access\n- `sc_output.json` (phase output — server merges into cv_assembly_state.json at join)\n\n### NEVER Modify\n- `candidate_profile.json`\n- `project_memory.json`\n\n---\n\n## Tools\n\n| Tool | Usage |\n| --- | --- |\n| **ReadFile** | Read JSON files by filename |\n| **WriteFile** | Write updated cv_assembly_state.json |\n| **SwitchAgent** | Return control to Assembly Coordinator when complete |\n\n**⚠️ CRITICAL:**\n- WriteFile accepts STRINGS only: `JSON.stringify(data, null, 2)`\n- Use bare filenames: `\"sc_output.json\"` not `\"/sc_output.json\"`\n- Do NOT write `cv_assembly_state.json` — server merges at join\n\n---\n\n## Context Object Received\n\nAssembly Coordinator passes this context:\n```json\n{\n  \"cv_state_path\": \"cv_assembly_state.json\",\n  \"profile_path\": \"candidate_profile.json\",\n  \"project_path\": \"project_memory.json\"\n}\n```\n\n---\n\n## Execution Protocol\n\n### Phase 0: Validate Required Files\n\n```javascript\n// Attempt to read required files — if any fail, handle gracefully\n// cv_assembly_state.json is read first to check current_phase\nconst cvStateContent = ReadFile(\"cv_assembly_state.json\")\nif (!cvStateContent) {\n  Display: \"Error: cv_assembly_state.json not found. Please check project setup.\"\n  ChangeAgent(agent: \"Main Orchestrator\")\n  END TURN\n}\n```\n\n---\n\n### Phase 1: Load Data\n\n**Use ReadFile tool for each file:**\n```javascript\n// Read candidate profile\nconst candidateProfile = JSON.parse(ReadFile(\"candidate_profile.json\"))\n\n// Read project memory\nconst projectMemory = JSON.parse(ReadFile(\"project_memory.json\"))\n\n// Read CV assembly state (already loaded in Phase 0)\nconst cvState = JSON.parse(ReadFile(\"cv_assembly_state.json\"))\n\n// Verify Style Negotiation complete (parallel dispatch — current_phase is not agent-specific)\nif (cvState.phases[0].status !== \"COMPLETE\") {\n  Display: \"Error: Style Negotiation not complete. Cannot proceed.\"\n  END TURN\n}\n\n// Extract data\nconst allSkills = candidateProfile.skills\nconst gapAnalysis = projectMemory.gap_analysis\nconst strengthSkills = gapAnalysis.strengths.map(s => s.skill_or_attribute)\nconst atsKeywords = gapAnalysis.ats_keywords.found_keywords\n```\n\n---\n\n### Phase 2: Categorize & Prioritize\n\n```javascript\n// Categorize skills\nconst technical = []\nconst soft = []\nconst certifications = candidateProfile.skills?.certifications\n  || candidateProfile.additional_information?.certifications\n  || []\n\n// Prioritize: strengths first, then other skills\nconst strengthSkillsSet = new Set(strengthSkills.map(s => s.toLowerCase()))\n\n// Get all unique skills\nconst allCoreSkills = candidateProfile.skills.core_competencies || []\nconst allTechSkills = candidateProfile.skills.technical_skills || []\nconst allSoftSkills = candidateProfile.skills.soft_skills || []\n\n// Combine and deduplicate\nconst allUniqueSkills = [\n  ...new Set([\n    ...strengthSkills,\n    ...allCoreSkills,\n    ...allTechSkills,\n    ...allSoftSkills\n  ])\n]\n\n// Categorize each skill\nallUniqueSkills.forEach(skill => {\n  const skillLower = skill.toLowerCase()\n\n  // Check if technical — primary: exact match in allTechSkills list from candidate_profile\n  // Secondary: keyword heuristic for common tool categories\n  const isTech =\n    allTechSkills.some(ts => ts.toLowerCase() === skillLower) ||\n    skillLower.includes('python') ||\n    skillLower.includes('java') ||\n    skillLower.includes('sql') ||\n    skillLower.includes('excel') ||\n    skillLower.includes('tableau') ||\n    skillLower.includes('sap') ||\n    skillLower.includes('wms') ||\n    skillLower.includes('erp')\n\n  if (isTech) {\n    technical.push(skill)\n  } else {\n    soft.push(skill)\n  }\n})\n\n// Prioritize strengths within each category\nconst prioritizeTech = []\nconst prioritizeSoft = []\n\ntechnical.forEach(skill => {\n  if (strengthSkillsSet.has(skill.toLowerCase())) {\n    prioritizeTech.unshift(skill) // Add to front\n  } else {\n    prioritizeTech.push(skill) // Add to back\n  }\n})\n\nsoft.forEach(skill => {\n  if (strengthSkillsSet.has(skill.toLowerCase())) {\n    prioritizeSoft.unshift(skill)\n  } else {\n    prioritizeSoft.push(skill)\n  }\n})\n\n// Limit to top 8-12 total\nconst maxTechnical = 10\nconst maxSoft = 6\nconst maxCerts = 3\n\nconst formattedSkills = {\n  technical: prioritizeTech.slice(0, maxTechnical),\n  soft_skills: prioritizeSoft.slice(0, maxSoft),\n  certifications: certifications.slice(0, maxCerts)\n}\n```\n\n---\n\n### Phase 3: Optimize for ATS Keywords\n\n```javascript\n// Ensure critical ATS keywords are included\nconst atsKeywordsSet = new Set(atsKeywords.map(k => k.toLowerCase()))\nconst currentSkillsSet = new Set([\n  ...formattedSkills.technical.map(s => s.toLowerCase()),\n  ...formattedSkills.soft_skills.map(s => s.toLowerCase())\n])\n\n// Add missing ATS keywords if space available\natsKeywords.forEach(keyword => {\n  const keywordLower = keyword.toLowerCase()\n\n  if (!currentSkillsSet.has(keywordLower) && formattedSkills.technical.length < maxTechnical) {\n    formattedSkills.technical.push(keyword)\n  }\n})\n```\n\n---\n\n### Phase 4: Display & Write sc_output.json\n\nDisplay the skills list as an informational background bubble (no user input required):\n\n```markdown\n## Skills Section Built\n\n**Technical Skills (${formattedSkills.technical.length}):**\n${formattedSkills.technical.join(\", \")}\n\n**Soft Skills (${formattedSkills.soft_skills.length}):**\n${formattedSkills.soft_skills.join(\", \")}\n\n**Certifications (${formattedSkills.certifications.length}):**\n${formattedSkills.certifications.length > 0 ? formattedSkills.certifications.join(\", \") : \"None\"}\n```\n\nThen immediately write the output file:\n\n```javascript\nconst tailoringNotes = atsKeywords\n  .filter(kw => {\n    const kwLower = kw.toLowerCase()\n    return [...formattedSkills.technical, ...formattedSkills.soft_skills]\n      .some(s => s.toLowerCase().includes(kwLower))\n  })\n  .slice(0, 5)\n  .map(kw => `Included ATS keyword: \"${kw}\"`)\n\nconst phaseOutput = {\n  phase_number: 3,\n  phase_name: \"Skills Curation\",\n  agent: \"Skills Curator\",\n  status: \"COMPLETE\",\n  completed_at: getCurrentISOTimestamp(),\n  data: {\n    technical_skills: formattedSkills.technical,\n    soft_skills: formattedSkills.soft_skills,\n    certifications: formattedSkills.certifications,\n    total_skills: formattedSkills.technical.length + formattedSkills.soft_skills.length,\n    ats_optimized: true,\n    tailoring_notes: tailoringNotes.join(\"; \"),\n    user_confirmed: true\n  }\n}\n\nWriteFile(\"sc_output.json\", JSON.stringify(phaseOutput, null, 2))\n\nconst verified = JSON.parse(ReadFile(\"sc_output.json\"))\nif (verified.status !== \"COMPLETE\") {\n  Display: \"Error: Failed to write sc_output.json.\"\n  END TURN\n}\n\n// Display turn-based completion\nDisplay: `\n# ✓ Skills Curator Complete\n\nSkills section organized and ATS-optimized.\n- Technical skills: {formattedSkills.technical.length}\n- Soft skills: {formattedSkills.soft_skills.length}\n- Certifications: {formattedSkills.certifications.length}\n\n// TURN ENDS. Canvas fires done_SC = 1 from text output. Server handles dispatch.\n```\n\n---\n\n## Error Handling\n\n| Error | Action |\n| --- | --- |\n| File not found | Display error, ChangeAgent(\"Main Orchestrator\") |\n| Phase mismatch | Display error about routing issue, ChangeAgent(\"Assembly Coordinator\") |\n| JSON parse error | Display error, ChangeAgent(\"Main Orchestrator\") |\n| WriteFile fails | Display error, retry once, then ChangeAgent(\"Main Orchestrator\") |\n| Skills extraction empty | Use fallback from user_profile, continue |\n\n---\n\n## Critical Rules\n\n**`getCurrentISOTimestamp()` implementation** — When writing any date/time field, extract the current date from the system context (\"Today's date is YYYY-MM-DD\") and return it as ISO 8601: `YYYY-MM-DDT00:00:00Z`. **Never hardcode a specific date string** (e.g. \"2026-03-31T00:00:00Z\") — that is a fabrication error. If no system date is visible, use the most recent date mentioned in the conversation.\n\n1. **Use bare filenames** — `\"sc_output.json\"` not `\"/sc_output.json\"`\n2. **Always stringify JSON** — `JSON.stringify(data, null, 2)` before WriteFile\n3. **Verify writes** — Read file back to confirm\n4. **Write to sc_output.json only** — Server merges into cv_assembly_state.json at join; do NOT write cv_assembly_state.json\n5. **No current_phase advancement** — Server sets current_phase = 7 after all 5 agents complete\n6. **candidate_profile.json** — NEVER user_profile.json\n7. **Turn-based pattern** — Display \"# ✓ Skills Curator Complete\" and end turn naturally\n8. **No SwitchAgent on completion** — canvas fires `done_SC = 1`; server handles dispatch\n\n---\n\n## Expected Workflow\n\n```\nServer dispatches Skills Curator in parallel with PB/HF/CF/CLW (after done_SN fires)\nSkills Curator: ReadFile(\"cv_assembly_state.json\") — verify phases[0].status = \"COMPLETE\"\nSkills Curator: ReadFile(\"candidate_profile.json\")\nSkills Curator: ReadFile(\"project_memory.json\")\nSkills Curator: Extract, categorize, prioritize skills\nSkills Curator: Optimize for ATS keywords\nSkills Curator: Display skills list to user, wait for confirmation\nSkills Curator: WriteFile(\"sc_output.json\") with status = \"COMPLETE\"\nSkills Curator: Display \"# ✓ Skills Curator Complete\"\n[TURN ENDS — canvas fires done_SC = 1]\nServer: when all 5 done flags set → merge into cv_assembly_state.json → dispatch Style Reviewer\n```\n\n---\n\n## File Structure After Completion\n\n**sc_output.json:**\n```json\n{\n  \"phase_number\": 3,\n  \"phase_name\": \"Skills Curation\",\n  \"agent\": \"Skills Curator\",\n  \"status\": \"COMPLETE\",\n  \"completed_at\": \"ISO timestamp\",\n  \"data\": {\n    \"technical_skills\": [\"Python\", \"SQL\", \"SAP\", ...],\n    \"soft_skills\": [\"Leadership\", \"Communication\", ...],\n    \"certifications\": [\"Six Sigma\", ...],\n    \"total_skills\": 14,\n    \"ats_optimized\": true,\n    \"tailoring_notes\": \"Included ATS keyword: ...\",\n    \"user_confirmed\": true\n  }\n}\n```\n\n---\n\n","query":"","jsonResponse":false,"jsonFormat":"","jsonSchemaMode":"typescript","fileParser":"native","imageAspectRatio":"1:1","maxIterations":12,"reasoningEffort":"medium","allowFallbacks":true,"temperature":1},"service":{"name":"kemu.io.ai-agent","version":"1.8.2","title":"AI Agent","description":"Define AI agents and tools for automated workflows","processor":"js","widgetUI":true,"settingsUI":false,"eventEmitter":true,"ignoreParentEvents":false,"svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-102.48l-82.801-189.72c-6.4805-14.762-27.359-14.762-33.719 0l-82.801 189.72c-20.039 45.961-56.641 82.559-102.48 102.48l-190.08 82.922c-14.641 6.4805-14.762 27.238 0 33.719l193.44 85.441c45.719 20.281 82.199 57 102 103.08l80.039 186.12c6.3594 14.762 27.359 14.879 33.84 0l82.68-189.6c19.922-45.84 56.52-82.441 102.48-102.48l189.72-82.801c14.762-6.3594 14.762-27.238 0-33.719zm-210.84-6.9609c-3 6.7188-9.6016 10.801-16.559 10.801-2.3984 0-4.8008-0.48047-7.1992-1.4414-64.078-28.078-114.72-78.719-142.68-142.8-4.0781-9.1211 0.12109-19.801 9.2383-23.762 9.1211-3.9609 19.68 0.23828 23.762 9.3594 24.238 55.68 68.398 99.84 124.08 124.2 9.1211 3.9609 13.32 14.52 9.3594 23.641z\"/>\n <path d=\"m1113.1 322.08-109.56-47.762c-26.52-11.641-47.641-32.762-59.281-59.281l-47.762-109.56c-3.7188-8.5195-15.84-8.5195-19.559 0l-47.762 109.56c-11.641 26.52-32.762 47.641-59.281 59.281l-109.68 47.879c-8.5195 3.7188-8.5195 15.719-0.12109 19.441l111.72 49.32c26.398 11.762 47.52 33 58.922 59.52l46.32 107.64c3.6016 8.5195 15.719 8.5195 19.441 0l47.762-109.44c11.641-26.52 32.762-47.641 59.281-59.281l109.56-47.762c8.5195-3.7188 8.5195-15.84 0-19.559zm-149.28 15.84c-3.4805 5.6406-9.3594 8.6406-15.48 8.6406-3.1211 0-6.3594-0.83984-9.2383-2.5195-24.84-15.121-45.359-34.922-61.199-59.16-5.3984-8.3984-3-19.441 5.2812-24.961 8.2812-5.3984 19.441-3.1211 24.84 5.2812 12.961 19.68 29.641 35.762 49.68 48 8.5195 5.1602 11.281 16.199 6.1211 24.719z\"/>\n</svg>\n","color":"#42a5f5","mdHelp":"/docs/help/service.md","customWidgets":[{"name":"Memory History","color":"#eac43e","description":"Provides a simple in-memory history manager for debugging purposes.","contents":"KMU-CB-v1{\"{#}mBE0gxc\":{\"id\":\"{#}mBE0gxc\",\"canvas\":{\"position\":{\"x\":2006,\"y\":726}},\"children\":[{\"childId\":\"{#}4M2WbT3\",\"sourcePort\":\"{#}mBE0gxc_innerOutput_inner-input-input1\",\"targetPort\":\"{#}4M2WbT3_input_agent\"}],\"state\":{\"description\":\"Provides a simple in-memory history manager for debugging purposes.\",\"inputs\":[{\"index\":0,\"label\":\"agent\",\"name\":\"input1\",\"type\":[5],\"position\":{\"x\":519,\"y\":291}}],\"outputs\":[],\"name\":\"Memory History\",\"type\":\"custom\",\"color\":\"#eac43e\",\"icon\":\"database\",\"canvasPosition\":{\"x\":0,\"y\":0},\"markdownHelp\":\"\",\"settings\":[],\"protocolVersion\":\"2\"},\"type\":\"widgetGroup\"},\"{#}4M2WbT3\":{\"id\":\"{#}4M2WbT3\",\"canvas\":{\"position\":{\"x\":659,\"y\":341}},\"children\":[{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_getHistory\",\"targetPort\":\"{#}jCnteeA_input_read\"},{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_updateHistory\",\"targetPort\":\"{#}jCnteeA_input_update\"}],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{\"includeAttachments\":false,\"timeout\":60},\"variantId\":\"history\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"groupId\":\"{#}mBE0gxc\"},\"{#}a5vxU9Y\":{\"id\":\"{#}a5vxU9Y\",\"canvas\":{\"position\":{\"x\":1235,\"y\":488}},\"children\":[],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{},\"variantId\":\"submit\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"secrets\":{\"OPENROUTER_API_KEY\":{\"name\":\"OPENROUTER_API_KEY\",\"hubServiceName\":\"kemu.io.ai-agent\"}},\"groupId\":\"{#}mBE0gxc\"},\"{#}jCnteeA\":{\"id\":\"{#}jCnteeA\",\"canvas\":{\"position\":{\"x\":948,\"y\":397}},\"children\":[{\"childId\":\"{#}a5vxU9Y\",\"sourcePort\":\"{#}jCnteeA_output_sessionHistoryOutput\",\"targetPort\":\"{#}a5vxU9Y_input_input\"}],\"state\":{\"pauseExecution\":false,\"autoPauseOnError\":true,\"version\":2,\"metadata\":{\"name\":\"Memory History\",\"description\":\"Keeps the history messages in memory (this is intended for dev purposes only)\"},\"pages\":{\"main\":{\"code\":\"/**\\n * Name: Memory History\\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\\n */\\n\\nconst sessions = {};\\n\\nconst getWidgetInputs = () => [\\n  { name: 'read', type: DataType.JsonObj },\\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\\n];\\n\\nconst getWidgetOutputs = () => [\\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\\n];\\n\\nconst onParentEvent = async ({ targetPort, event }) => {\\n  const inputData = event.data.value;\\n\\n  if (targetPort.name === 'read') {\\n    const sessionId = inputData.sessionId;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'read' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\\n\\n  } else if (targetPort.name === 'update') {\\n    const sessionId = inputData.sessionId;\\n    const messagesToProcess = inputData.messages;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'update' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n    if (messagesToProcess === undefined || messagesToProcess === null) {\\n      console.error(\\\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    if (Array.isArray(messagesToProcess)) {\\n      sessions[sessionId].messages.push(...messagesToProcess);\\n    } else {\\n      sessions[sessionId].messages.push(messagesToProcess);\\n    }\\n  }\\n};\",\"language\":\"javascript\",\"name\":\"My First Script\"}}},\"type\":\"script\",\"secrets\":{},\"groupId\":\"{#}mBE0gxc\"}}","rootGroupId":"{#}mBE0gxc","icon":"database","protocolVersion":"2"}],"inputs":[{"name":"config","description":"Configuration object containing query, attachments, sessionId, and systemInstructions. Can also be a string to be used as query or a boolean to trigger processing.","type":[5,4,1,6]},{"name":"abort","description":"Abort current query signal","type":6}],"outputs":[{"name":"tools","type":5},{"name":"history","type":5},{"name":"json","type":5},{"name":"text","type":1},{"name":"stream","type":1},{"name":"reasoning","description":"Reasoning output from models that support extended thinking","type":1},{"name":"images","description":"Generated images as ImageData array","type":3},{"name":"debug","description":"Includes debugging information for when things go wrong, including stopping reason","type":5}],"supportedPlatforms":["win-x86","win-x64","osx-x64","osx-arm64","linux-debian-arm64","linux-debian-x64","linux-rhel-arm64","linux-rhel-x64"],"author":"0f998d5a-a8ce-4bf8-9f84-fa8c481cb40b","defaultVariantInfo":{"title":"Agent","shortTitle":"Agent","description":"AI agent that processes queries with system instructions and attachments"},"variants":[{"id":"chatInterface","name":"Chat Interface","description":"Chat window U