66.16-33.516c18.188-18.188 43.266-29.391 71.016-29.391 27.703 0 52.828 11.25 71.016 29.391 18.188 18.188 29.391 43.266 29.391 71.016 0 27.703-11.25 52.828-29.391 71.016-18.188 18.188-43.266 29.391-71.016 29.391-27.703 0-52.828-11.25-71.016-29.391-18.188-18.188-29.391-43.266-29.391-71.016 0-27.703 11.25-52.828 29.391-71.016zm293.91 8.7227c11.109-8.9531 13.453-24.844 5.7188-36.562l-29.531-51.141c-6.9844-12.141-21.844-16.922-34.406-11.625l-41.672 16.031c-8.625-7.3125-17.906-13.875-27.75-19.547-9.7031-5.625-20.016-10.406-30.703-14.297l-7.0781-44.766c-2.1094-13.594-13.781-23.25-27.141-23.25v-0.09375h-60.75c-14.625 0-26.531 11.344-27.516 25.688l-6.6094 42.094c-10.828 3.6562-21.188 8.3906-30.891 14.016-9.9844 5.7656-19.312 12.469-28.031 20.109l-42.141-16.219c-12.797-4.875-27 0.42188-33.609 11.953l-30.328 52.594c-6.8438 11.859-3.7969 26.766 6.5625 35.109l35.297 28.547c-0.42188 2.5312-0.84375 5.0625-1.1719 7.6406-1.2188 8.9062-1.875 17.625-1.875 26.062s0.60938 17.203 1.875 26.062c0.32813 2.5781 0.75 5.1094 1.1719 7.6406l-35.297 28.547c-11.109 8.9531-13.453 24.844-5.7188 36.562l29.531 51.141c6.9844 12.188 21.844 16.922 34.406 11.625l41.672-16.031c8.625 7.3125 17.906 13.875 27.75 19.547 9.75 5.625 20.016 10.406 30.703 14.297l7.0781 44.766c2.1094 13.594 13.781 23.25 27.141 23.25v0.09375h60.75c14.625 0 26.531-11.344 27.516-25.688l6.7031-42.469c10.688-3.8438 20.953-8.6719 30.703-14.297 9.8438-5.6719 19.125-12.234 27.75-19.547l42.516 16.359c12.797 4.875 27-0.42188 33.609-11.953l30.328-52.594c6.8438-11.859 3.7969-26.766-6.5625-35.109l-35.297-28.547c0.46875-2.5312 0.84375-5.0625 1.1719-7.6406 1.2188-8.9062 1.875-17.625 1.875-26.062s-0.60937-17.203-1.875-26.062c-0.375-2.5781-0.75-5.1562-1.1719-7.6406l35.297-28.547z\" fill-rule=\"evenodd\"/>\n</svg>\n","inputs":[{"name":"input","description":"Data to submit","type":6}],"color":"#68bb6c"},{"id":"history","name":"History","description":"Manage conversation history and session storage for AI agents","svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m1003.2 198c-216-216-560.4-220.8-784.8-19.199l-60-60c-19.199-19.199-52.801-9.6016-58.801 16.801l-68.398 280.8c-6 25.199 16.801 49.199 43.199 43.199l280.8-68.398c26.398-6 36-39.602 16.801-58.801l-66-66c176.4-153.6 444-148.8 612 19.199 174 174 174 459.6-1.1992 634.8l-16.801 15.602c-25.199 22.801-26.398 61.199-4.8008 86.398 12 13.199 28.801 20.398 45.602 20.398 14.398 0 28.801-4.8008 40.801-15.602 7.1992-6 14.398-13.199 20.398-20.398 223.2-223.2 223.2-585.6 1.1992-808.8z\"/>\n <path d=\"m739.2 1028.4-22.801 7.1992c-32.398 8.3984-51.602 42-43.199 75.602 7.1992 27.602 32.398 45.602 58.801 45.602 4.8008 0 10.801-1.1992 15.602-2.3984 9.6016-2.3984 19.199-6 28.801-8.3984 32.398-10.801 49.199-45.602 38.398-76.801-8.4023-33.602-43.199-51.602-75.602-40.805z\"/>\n <path d=\"m532.8 1046.4-24-3.6016c-33.602-7.1992-66 14.398-72 48-7.1992 33.602 14.398 66 48 72 9.6016 2.3984 20.398 3.6016 30 4.8008 2.3984 0 6 1.1992 9.6016 1.1992 30 0 56.398-21.602 60-52.801 4.7969-33.598-18.004-64.797-51.602-69.598z\"/>\n <path d=\"m321.6 955.2c-26.398-20.398-64.801-16.801-86.398 9.6016-20.398 26.398-16.801 64.801 9.6016 86.398 8.3984 6 15.602 12 24 18 10.801 7.1992 22.801 10.801 34.801 10.801 19.199 0 38.398-8.3984 50.398-26.398 19.199-27.602 13.199-66-14.398-85.199z\"/>\n <path d=\"m192 793.2c-14.398-31.199-50.398-44.398-81.602-30-31.199 14.398-44.398 50.398-30 81.602 4.8008 9.6016 8.3984 18 13.199 27.602 10.801 20.398 32.398 32.398 54 32.398 9.6016 0 19.199-2.3984 28.801-7.1992 30-15.602 40.801-52.801 25.199-82.801z\"/>\n <path d=\"m800.4 657.6-140.4-90v-223.2c0-33.602-27.602-61.199-61.199-61.199-33.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n","inputs":[{"name":"agent","description":"Connect to the agent","type":5}],"outputs":[{"name":"getHistory","description":"Invoked when the agent needs to retrieve the conversation history","type":5},{"name":"updateHistory","description":"Invoked when the agent needs to update the conversation history","type":5}],"color":"#eac43e"}],"publicationId":"kemu.io.ai-agent-osx-arm64-1.8.2","sessionId":1775771906}},"type":"hubService","secrets":{"OPENROUTER_API_KEY":{"name":"OPENROUTER_API_KEY","sharedAcrossInstances":true,"hubServiceName":"kemu.io.ai-agent"}},"groupId":"{#}ATCt3ZJ"},"{#}W3VGQVK":{"id":"{#}W3VGQVK","canvas":{"position":{"x":800,"y":622}},"children":[{"childId":"{#}81bAKq3","sourcePort":"{#}W3VGQVK_output_sessionHistoryOutput","targetPort":"{#}81bAKq3_input_input"}],"state":{"pauseExecution":false,"autoPauseOnError":true,"version":2,"metadata":{"name":"Memory History","description":"Keeps the history messages in memory (this is intended for dev purposes only)"},"pages":{"main":{"code":"/**\n * Name: Memory History\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\n */\n\nconst sessions = {};\n\nconst getWidgetInputs = () => [\n  { name: 'read', type: DataType.JsonObj },\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\n];\n\nconst getWidgetOutputs = () => [\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\n];\n\nconst onParentEvent = async ({ targetPort, event }) => {\n  const inputData = event.data.value;\n\n  if (targetPort.name === 'read') {\n    const sessionId = inputData.sessionId;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'read' event missing 'sessionId' property.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\n\n  } else if (targetPort.name === 'update') {\n    const sessionId = inputData.sessionId;\n    const messagesToProcess = inputData.messages;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'update' event missing 'sessionId' property.\");\n      return;\n    }\n    if (messagesToProcess === undefined || messagesToProcess === null) {\n      console.error(\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    if (Array.isArray(messagesToProcess)) {\n      sessions[sessionId].messages.push(...messagesToProcess);\n    } else {\n      sessions[sessionId].messages.push(messagesToProcess);\n    }\n  }\n};","language":"javascript","name":"My First Script"}}},"type":"script","secrets":{},"groupId":"{#}ATCt3ZJ"},"{#}v3eCjBe":{"id":"{#}v3eCjBe","canvas":{"position":{"x":552,"y":238}},"children":[],"state":{"text":"# Agent Memory\n\nBasic in-memory history that allows the agent to remember chat history. This is a basic solution (make sure you instruct your agents to read and write a “memory” file using their available tools to persist progress to disk).\n","color":"#a9b8c2","size":{"width":917,"height":200},"locked":true},"type":"note","groupId":"{#}ATCt3ZJ"},"{#}FU04yFQ":{"id":"{#}FU04yFQ","canvas":{"position":{"x":1653,"y":1034}},"children":[{"childId":"{#}17OCKON","sourcePort":"{#}FU04yFQ_output_tools","targetPort":"{#}17OCKON_input_outer-input-input1"},{"childId":"{#}lCnOwQN","sourcePort":"{#}FU04yFQ_output_history","targetPort":"{#}lCnOwQN_input_outer-input-input1"},{"childId":"{#}64dhk6C","sourcePort":"{#}FU04yFQ_output_reasoning","targetPort":"{#}64dhk6C_input_setValue"},{"childId":"{#}YhOejp5","sourcePort":"{#}FU04yFQ_output_debug","targetPort":"{#}YhOejp5_input_setValue"},{"childId":"{#}vvsdaBb","sourcePort":"{#}FU04yFQ_output_text","targetPort":"{#}vvsdaBb_input_setValue"}],"state":{"dynamicInputs":{},"dynamicOutputs":{},"customState":{"selectedModel":{"id":"google/gemini-3-flash-preview","slug":"google/gemini-3-flash-preview-20251217","name":"Google: Gemini 3 Flash Preview","description":"Gemini 3 Flash Preview is a high speed, high value thinking model designed for agentic workflows, multi turn chat, and coding assistance. It delivers near Pro level reasoning and tool use performance with substantially lower latency than larger Gemini variants, making it well suited for interactive development, long running agent loops, and collaborative coding tasks. Compared to Gemini 2.5 Flash, it provides broad quality improvements across reasoning, multimodal understanding, and reliability.\n\nThe model supports a 1M token context window and multimodal inputs including text, images, audio, video, and PDFs, with text output. It includes configurable reasoning via thinking levels (minimal, low, medium, high), structured output, tool use, and automatic context caching. Gemini 3 Flash Preview is optimized for users who want strong reasoning and agentic behavior without the cost or latency of full scale frontier models.","inputModalities":["text","image","file","audio","video"],"outputModalities":["text"],"supportsTools":true,"supportsReasoning":true,"promptPrice":5e-7,"completionPrice":0.000003,"maxTokens":65536,"contextLength":1048576,"provider":"google"},"systemInstructions":"# Style Reviewer v1.5 — System Instructions\n\n**Version:** 1.5\n**Last Updated:** 2026-04-01\n**Role:** Style Consistency Verifier\n**Pipeline Position:** Assembly Phase 7\n**Trigger:** `current_phase = 7` in cv_assembly_state.json\n**Output:** Updates `phases[6]`, sets `current_phase = 8`\n\n---\n\n## Role\n\nYou verify all CV sections follow agreed style overrides:\n- Check for \"I\" pronouns if removed\n- Verify telegraphic formatting if applied\n- Confirm bold emphasis on metrics\n- Ensure consistent structure\n\n---\n\n## Execution Protocol\n\n### Phase 1: Load All CV Sections\n```javascript\nconst cvState = JSON.parse(ReadFile(\"cv_assembly_state.json\"))\n\n// Validate phase\nif (cvState.current_phase !== 7) {\n  ERROR: `Wrong phase - expected 7, got ${cvState.current_phase}`\n  Display: \"Style Reviewer called at wrong time. Returning to Assembly Coordinator.\"\n  SwitchAgent(target: \"Assembly Coordinator\")\n  END TURN\n}\n\n// Read agreed overrides from Phase 1 (Style Negotiator)\nconst styleOverrides = cvState.phases[0].data?.agreed_overrides || []\n\n// Read section data from completed phases\nconst profile = cvState.phases[1].data?.profile_paragraph?.formatted_text || \"\"\nconst skills = cvState.phases[2].data || {}\nconst history = cvState.phases[3].data?.formatted_entries || []\nconst credentials = cvState.phases[4].data || {}\n// Use coverletter_body for style checks (body text only, not header/sign-off)\nconst coverletter = cvState.phases[5].data?.coverletter_body || cvState.phases[5].data?.coverletter_text || \"\"\n```\n\n---\n\n### Phase 2: Check Each Override\n```javascript\nconst issues = []\n// Track per-section verdicts for detailed reporting\nconst sectionResults = {\n  profile:     { checked: true, issues: [] },\n  skills:      { checked: true, issues: [] },\n  history:     { checked: true, issues: [] },\n  credentials: { checked: true, issues: [] },\n  coverletter: { checked: !!coverletter, issues: [] }\n}\n\n// ── CV section style checks ───────────────────────────────────────────────\n\n// Check for \"I\" pronouns if should be removed (applies to CV sections only)\nif (styleOverrides.some(o => o.toLowerCase().includes(\"implicit first-person\"))) {\n  if (profile.match(/\\bI\\s/i)) {\n    const msg = \"Found 'I' pronouns in profile paragraph\"\n    issues.push(msg); sectionResults.profile.issues.push(msg)\n  }\n  if (history.some(h => h.bullets.some(b => b.match(/\\bI\\s/i)))) {\n    const msg = \"Found 'I' pronouns in history bullets\"\n    issues.push(msg); sectionResults.history.issues.push(msg)\n  }\n}\n\n// Check for periods if telegraphic style\nif (styleOverrides.some(o => o.toLowerCase().includes(\"telegraphic\"))) {\n  if (history.some(h => h.bullets.some(b => b.endsWith(\".\")))) {\n    const msg = \"Found trailing periods in history bullets (telegraphic style: remove)\"\n    issues.push(msg); sectionResults.history.issues.push(msg)\n  }\n}\n\n// Check for bold metrics if required\nif (styleOverrides.some(o => o.toLowerCase().includes(\"bold achievements\"))) {\n  if (!history.some(h => h.bullets.some(b => b.match(/\\*\\*\\d+/)))) {\n    const msg = \"No bold metrics found in history achievements\"\n    issues.push(msg); sectionResults.history.issues.push(msg)\n  }\n}\n\n// ── Cover letter banned phrases check ────────────────────────────────────\n// Must run on cover letter body text regardless of style overrides\nconst coverletterBannedPhrases = [\n  \"I am writing to express my strong interest\",\n  \"I am eager to contribute\",\n  \"I am uniquely positioned\",\n  \"I am inspired by\",\n  \"I would be a great fit\",\n  \"I am passionate about\",\n  \"I look forward to the opportunity to\",\n  \"I look forward to hearing from you\",\n  \"I pride myself on\",\n  \"I pride myself in\",\n  \"my passion for\",\n  \"my strong passion\",\n  \"I am excited to\",\n  \"I am thrilled to\"\n]\n\nif (coverletter) {\n  const coverletterLower = coverletter.toLowerCase()\n  coverletterBannedPhrases.forEach(phrase => {\n    if (coverletterLower.includes(phrase.toLowerCase())) {\n      const msg = `Banned phrase in cover letter: \"${phrase}\"`\n      issues.push(msg); sectionResults.coverletter.issues.push(msg)\n    }\n  })\n} else {\n  sectionResults.coverletter.checked = false\n  sectionResults.coverletter.issues.push(\"Cover letter text not available — skipped\")\n}\n```\n\n---\n\n### Phase 3: Report & Fix (Auto-Fix Minor Issues)\n```javascript\nif (issues.length === 0) {\n  styleCompliance = \"PASS\"\n} else if (issues.length <= 2) {\n  // Auto-fix minor issues\n  styleCompliance = \"PASS_WITH_FIXES\"\n  // Apply corrections to profile, history bullets as needed...\n} else {\n  styleCompliance = \"FAIL\"\n  // Set exception status BEFORE writing so AC exception handler sees it\n  cvState.metadata.status = \"STYLE_FAILED\"\n}\n```\n\n---\n\n### Phase 4: Update State, Display Completion, and Return\n```javascript\n// Schema preservation: restore change_log if dropped by prior agents (BUG-54 cascade)\nif (!Array.isArray(cvState.change_log)) {\n  cvState.change_log = []\n}\n\n// Prohibition: do NOT write any fields to cvState.metadata except the ones below.\n// Never add final_cv, current_phase, or any other fields inside metadata.\ncvState.phases[6].status = \"COMPLETE\"\ncvState.phases[6].completed_at = getCurrentISOTimestamp()\n// Collect auto-fixes applied (minor issues that were corrected without user input)\nconst fixesApplied = issues.filter(i => i.auto_fixed === true).map(i => i.description || String(i))\n\ncvState.phases[6].data = {\n  style_compliance: styleCompliance,\n  verdict: styleCompliance,    // alias field — AC checks integrityData.passed via style_compliance === \"PASS\"\n  issues_found: issues,\n  issues_count: issues.length,\n  fixes_applied: fixesApplied, // list of auto-applied minor corrections; empty array if none\n  sections_checked: Object.values(sectionResults).filter(s => s.checked).length,\n  sections_excluded: Object.values(sectionResults).filter(s => !s.checked).length,\n  section_verdicts: {\n    profile:     { checked: sectionResults.profile.checked,     issues: sectionResults.profile.issues,     passed: sectionResults.profile.issues.length === 0 },\n    skills:      { checked: sectionResults.skills.checked,      issues: sectionResults.skills.issues,      passed: sectionResults.skills.issues.length === 0 },\n    history:     { checked: sectionResults.history.checked,     issues: sectionResults.history.issues,     passed: sectionResults.history.issues.length === 0 },\n    credentials: { checked: sectionResults.credentials.checked, issues: sectionResults.credentials.issues, passed: sectionResults.credentials.issues.length === 0 },\n    coverletter:  { checked: sectionResults.coverletter.checked,  issues: sectionResults.coverletter.issues,  passed: sectionResults.coverletter.checked && sectionResults.coverletter.issues.length === 0 }\n  }\n}\n\ncvState.current_phase = 8\ndelete cvState.metadata.current_phase  // Remove any metadata.current_phase pollution\ncvState.metadata.completed_phases += 1\ncvState.metadata.last_updated = getCurrentISOTimestamp()\n\nWriteFile({ fileName: \"cv_assembly_state.json\", filePath: \"\", contents: JSON.stringify(cvState, null, 2 }))\n```\n\nThen display and return:\n\n```javascript\nIF styleCompliance === \"FAIL\":\n  // Exception path — user must review before continuing\n  Display: `\n## ⚠ Style Review Failed\n\n${issues.length} style issues found that require attention:\n${issues.map(i => `• ${i}`).join('\\n')}\n\n---\n\nSend any message to return to Assembly Coordinator for review options.\n`\n  WAIT for user message\n  SwitchAgent(target: \"Assembly Coordinator\", context: {})\n\nELSE:\n  // Happy path (PASS or PASS_WITH_FIXES) — no user turn needed, chain to IC\n  Display: `\n# ✓ Style Reviewer Complete\n\nStyle consistency check complete.\n- Compliance: {styleCompliance}\n- Issues found: {issues.length}\n- Sections checked: 5\n`\n  // No waiting — immediately hand back to AC which routes to Integrity Checker\n  SwitchAgent(target: \"Assembly Coordinator\", context: {})\n```\n\n---\n\n## ⚠️ Critical Rules\n\n**`getCurrentISOTimestamp()` implementation** — When writing any date/time field, extract the current date from the system context (\"Today's date is YYYY-MM-DD\") and return it as ISO 8601: `YYYY-MM-DDT00:00:00Z`. **Never hardcode a specific date string** (e.g. \"2026-03-31T00:00:00Z\") — that is a fabrication error. If no system date is visible, use the most recent date mentioned in the conversation.\n\n1. **Use bare filenames** — `\"cv_assembly_state.json\"` not `\"/cv_assembly_state.json\"`\n2. **No leading slashes** — Never start filename with `/`\n3. **Always stringify JSON** — `WriteFile({ fileName: \"file.json\", filePath: \"\", contents: JSON.stringify(data, null, 2 }))`\n4. **Read section data from phases array** — `cvState.phases[N].data`, not `cvState.sections`\n5. **Read style overrides from phases[0].data** — Not from old sections schema\n6. **Update phases[6] only** — Array index 6\n7. **Advance to Phase 8** — Set current_phase = 8\n8. **No user turn on happy path** — PASS/PASS_WITH_FIXES: display completion, immediately SwitchAgent(\"Assembly Coordinator\"). Only FAIL path waits for user.\n9. **Return to Assembly Coordinator** — Always SwitchAgent(\"Assembly Coordinator\") when done\n10. **Use actual current date** — Never hardcode timestamps\n11. **Check cover letter banned phrases** — Always run banned phrases check on `coverletter_body`. This check is mandatory and not gated on style overrides. \"I pride myself on\" and all other banned phrases must be flagged as issues if found.\n12. **Detailed section_verdicts required** — phases[6].data must include `section_verdicts` with per-section pass/fail and issue lists. A sparse data object (only compliance + count) is insufficient.\n13. **Never write extra fields to metadata** — Only update `completed_phases`, `last_updated`, and `status` (on FAIL). Never add `final_cv`, `current_phase`, or any other fields inside `cvState.metadata`.\n14. **Restore change_log if missing** — If `cvState.change_log` is absent (dropped by prior agents), initialise it as an empty array before writing.\n\n---\n\n*End of Style Reviewer v1.4*","query":"","jsonResponse":false,"jsonFormat":"","jsonSchemaMode":"typescript","fileParser":"native","imageAspectRatio":"1:1","maxIterations":12,"reasoningEffort":"medium","allowFallbacks":true,"temperature":1},"service":{"name":"kemu.io.ai-agent","version":"1.8.2","title":"AI Agent","description":"Define AI agents and tools for automated workflows","processor":"js","widgetUI":true,"settingsUI":false,"eventEmitter":true,"ignoreParentEvents":false,"svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-102.48l-82.801-189.72c-6.4805-14.762-27.359-14.762-33.719 0l-82.801 189.72c-20.039 45.961-56.641 82.559-102.48 102.48l-190.08 82.922c-14.641 6.4805-14.762 27.238 0 33.719l193.44 85.441c45.719 20.281 82.199 57 102 103.08l80.039 186.12c6.3594 14.762 27.359 14.879 33.84 0l82.68-189.6c19.922-45.84 56.52-82.441 102.48-102.48l189.72-82.801c14.762-6.3594 14.762-27.238 0-33.719zm-210.84-6.9609c-3 6.7188-9.6016 10.801-16.559 10.801-2.3984 0-4.8008-0.48047-7.1992-1.4414-64.078-28.078-114.72-78.719-142.68-142.8-4.0781-9.1211 0.12109-19.801 9.2383-23.762 9.1211-3.9609 19.68 0.23828 23.762 9.3594 24.238 55.68 68.398 99.84 124.08 124.2 9.1211 3.9609 13.32 14.52 9.3594 23.641z\"/>\n <path d=\"m1113.1 322.08-109.56-47.762c-26.52-11.641-47.641-32.762-59.281-59.281l-47.762-109.56c-3.7188-8.5195-15.84-8.5195-19.559 0l-47.762 109.56c-11.641 26.52-32.762 47.641-59.281 59.281l-109.68 47.879c-8.5195 3.7188-8.5195 15.719-0.12109 19.441l111.72 49.32c26.398 11.762 47.52 33 58.922 59.52l46.32 107.64c3.6016 8.5195 15.719 8.5195 19.441 0l47.762-109.44c11.641-26.52 32.762-47.641 59.281-59.281l109.56-47.762c8.5195-3.7188 8.5195-15.84 0-19.559zm-149.28 15.84c-3.4805 5.6406-9.3594 8.6406-15.48 8.6406-3.1211 0-6.3594-0.83984-9.2383-2.5195-24.84-15.121-45.359-34.922-61.199-59.16-5.3984-8.3984-3-19.441 5.2812-24.961 8.2812-5.3984 19.441-3.1211 24.84 5.2812 12.961 19.68 29.641 35.762 49.68 48 8.5195 5.1602 11.281 16.199 6.1211 24.719z\"/>\n</svg>\n","color":"#42a5f5","mdHelp":"/docs/help/service.md","customWidgets":[{"name":"Memory History","color":"#eac43e","description":"Provides a simple in-memory history manager for debugging purposes.","contents":"KMU-CB-v1{\"{#}mBE0gxc\":{\"id\":\"{#}mBE0gxc\",\"canvas\":{\"position\":{\"x\":2006,\"y\":726}},\"children\":[{\"childId\":\"{#}4M2WbT3\",\"sourcePort\":\"{#}mBE0gxc_innerOutput_inner-input-input1\",\"targetPort\":\"{#}4M2WbT3_input_agent\"}],\"state\":{\"description\":\"Provides a simple in-memory history manager for debugging purposes.\",\"inputs\":[{\"index\":0,\"label\":\"agent\",\"name\":\"input1\",\"type\":[5],\"position\":{\"x\":519,\"y\":291}}],\"outputs\":[],\"name\":\"Memory History\",\"type\":\"custom\",\"color\":\"#eac43e\",\"icon\":\"database\",\"canvasPosition\":{\"x\":0,\"y\":0},\"markdownHelp\":\"\",\"settings\":[],\"protocolVersion\":\"2\"},\"type\":\"widgetGroup\"},\"{#}4M2WbT3\":{\"id\":\"{#}4M2WbT3\",\"canvas\":{\"position\":{\"x\":659,\"y\":341}},\"children\":[{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_getHistory\",\"targetPort\":\"{#}jCnteeA_input_read\"},{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_updateHistory\",\"targetPort\":\"{#}jCnteeA_input_update\"}],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{\"includeAttachments\":false,\"timeout\":60},\"variantId\":\"history\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"groupId\":\"{#}mBE0gxc\"},\"{#}a5vxU9Y\":{\"id\":\"{#}a5vxU9Y\",\"canvas\":{\"position\":{\"x\":1235,\"y\":488}},\"children\":[],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{},\"variantId\":\"submit\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"secrets\":{\"OPENROUTER_API_KEY\":{\"name\":\"OPENROUTER_API_KEY\",\"hubServiceName\":\"kemu.io.ai-agent\"}},\"groupId\":\"{#}mBE0gxc\"},\"{#}jCnteeA\":{\"id\":\"{#}jCnteeA\",\"canvas\":{\"position\":{\"x\":948,\"y\":397}},\"children\":[{\"childId\":\"{#}a5vxU9Y\",\"sourcePort\":\"{#}jCnteeA_output_sessionHistoryOutput\",\"targetPort\":\"{#}a5vxU9Y_input_input\"}],\"state\":{\"pauseExecution\":false,\"autoPauseOnError\":true,\"version\":2,\"metadata\":{\"name\":\"Memory History\",\"description\":\"Keeps the history messages in memory (this is intended for dev purposes only)\"},\"pages\":{\"main\":{\"code\":\"/**\\n * Name: Memory History\\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\\n */\\n\\nconst sessions = {};\\n\\nconst getWidgetInputs = () => [\\n  { name: 'read', type: DataType.JsonObj },\\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\\n];\\n\\nconst getWidgetOutputs = () => [\\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\\n];\\n\\nconst onParentEvent = async ({ targetPort, event }) => {\\n  const inputData = event.data.value;\\n\\n  if (targetPort.name === 'read') {\\n    const sessionId = inputData.sessionId;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'read' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\\n\\n  } else if (targetPort.name === 'update') {\\n    const sessionId = inputData.sessionId;\\n    const messagesToProcess = inputData.messages;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'update' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n    if (messagesToProcess === undefined || messagesToProcess === null) {\\n      console.error(\\\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    if (Array.isArray(messagesToProcess)) {\\n      sessions[sessionId].messages.push(...messagesToProcess);\\n    } else {\\n      sessions[sessionId].messages.push(messagesToProcess);\\n    }\\n  }\\n};\",\"language\":\"javascript\",\"name\":\"My First Script\"}}},\"type\":\"script\",\"secrets\":{},\"groupId\":\"{#}mBE0gxc\"}}","rootGroupId":"{#}mBE0gxc","icon":"database","protocolVersion":"2"}],"inputs":[{"name":"config","description":"Configuration object containing query, attachments, sessionId, and systemInstructions. Can also be a string to be used as query or a boolean to trigger processing.","type":[5,4,1,6]},{"name":"abort","description":"Abort current query signal","type":6}],"outputs":[{"name":"tools","type":5},{"name":"history","type":5},{"name":"json","type":5},{"name":"text","type":1},{"name":"stream","type":1},{"name":"reasoning","description":"Reasoning output from models that support extended thinking","type":1},{"name":"images","description":"Generated images as ImageData array","type":3},{"name":"debug","description":"Includes debugging information for when things go wrong, including stopping reason","type":5}],"supportedPlatforms":["win-x86","win-x64","osx-x64","osx-arm64","linux-debian-arm64","linux-debian-x64","linux-rhel-arm64","linux-rhel-x64"],"author":"0f998d5a-a8ce-4bf8-9f84-fa8c481cb40b","defaultVariantInfo":{"title":"Agent","shortTitle":"Agent","description":"AI agent that processes queries with system instructions and attachments"},"variants":[{"id":"chatInterface","name":"Chat Interface","description":"Chat window UI that can invoke an Agent and display live outputs","svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\