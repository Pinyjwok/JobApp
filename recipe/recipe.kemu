put"}],"state":{"text":"Failed to conduct research: {{input.error.message}}","format":"Text","size":{"width":220,"height":135}},"type":"templateString","groupId":"{#}YrQTccT"},"{#}3oC8qYi":{"id":"{#}3oC8qYi","canvas":{"position":{"x":3359,"y":671}},"children":[{"childId":"{#}10TE45C","sourcePort":"{#}3oC8qYi_output_summary","targetPort":"{#}10TE45C_input_input"},{"childId":"{#}MFJoccA","sourcePort":"{#}3oC8qYi_output_error","targetPort":"{#}MFJoccA_input_input"}],"state":{"pauseExecution":false,"autoPauseOnError":true,"version":2,"metadata":{"name":"Tavily Search Tool","description":"Performs a token-efficient search tailored for AI agents."},"pages":{"main":{"code":"  /**                                                                                                   \n   * Name: Tavily Search Tool                                                                           \n   * Description: Performs a token-efficient search tailored for AI agents.                             \n   */\n                                                                                                        \n  const getWidgetInputs = () => [                                                                                                                                                    \n    { name: 'query', type: DataType.String },                                                                                                                                        \n    { name: 'sector', type: DataType.String }                                                                                                                                        \n  ];                                                                                                                                                                                 \n                                                                                                                                                                                     \n  const getWidgetOutputs = () => [                                                                                                                                                   \n    { name: 'summary', type: DataType.String },                                                                                                                                      \n    { name: 'error', type: DataType.String }                                                                                                                                         \n  ];                                                                                                                                                                                 \n                                                                                                                                                                                     \n  Kemu.secrets.requestAccess('TAVILY_API_KEY');                                                                                                                                      \n                                                                                                                                                                                     \n  let storedSector = \"\";                                                                                                                                                             \n                                                                                                                                                                                     \n  const onParentEvent = async ({ targetPort, event }) => {                                                                                                                           \n                                                                                                                                                                                     \n    if (targetPort.name === 'sector' && event.data.value) {                                                                                                                          \n      storedSector = event.data.value;                                                                                                                                               \n      return;                                                                                                                                                                        \n    }                                                                                                                                                                                \n                                                                                                                                                                                     \n    if (targetPort.name === 'query' && event.data.value) {                                                                                                                           \n      try {                                                                                                                                                                          \n        const searchQuery = event.data.value;                                                                                                                                        \n        const secrets = await Kemu.secrets.read(['TAVILY_API_KEY']);                                                                                                                 \n        const apiKey = secrets['TAVILY_API_KEY'];                                                                                                                                    \n                                                                                                                                                                                     \n        const response = await fetch('https://api.tavily.com/search', {                                                                                                              \n          method: 'POST',                                                                                                                                                            \n          headers: { 'Content-Type': 'application/json' },                                                                                                                           \n          body: JSON.stringify({                                                                                                                                                     \n            api_key: apiKey,                                                                                                                                                         \n            query: searchQuery,                                                                                                                                                      \n            search_depth: \"advanced\",                                                                                                                                                \n            include_answer: true,                                                                                                                                                    \n            max_results: 10,                                                                                                                                                         \n            include_domains: [                                                                                                                                                       \n              \"linkedin.com\",                                                                                                                                                        \n              \"glassdoor.com\",                                                                                                                                                       \n              \"glassdoor.com.au\",                                                                                                                                                    \n              \"indeed.com\",                                                                                                                                                          \n              \"seek.com.au\"                                                                                                                                                          \n            ]                                                                                                                                                                        \n          })                                                                                                                                                                         \n        });                                                                                                                                                                          \n                                                                                                                                                                                     \n        const data = await response.json();                                                                                                                                       \n\n        if (data && data.results) {\n          const aiAnswer = data.answer ? `AI Summary: ${data.answer}\\n\\n` : '';                                                                                                      \n          let finalContext = `${aiAnswer}Sources:\\n`;                                                                                                                                \n                                                                                                                                                                                     \n          data.results.forEach((item, i) => {                                                                                                                                        \n            finalContext += `[${i + 1}] ${item.title}\\n   URL: ${item.url}\\n   ${item.content}\\n\\n`;                                                                                 \n          });                                                                                                                                                                        \n                                                                                                                                                                                     \n          await setOutput({                                                                                                                                                          \n            port: 'summary',                                                                                                                                                         \n            data: { type: DataType.String, value: finalContext }                                                                                                                     \n          });                                                                                                                                                                        \n        } else {                                                                                                                                                                     \n          throw new Error(\"Tavily returned an empty or invalid response\");                                                                                                           \n        }                                                                                                                                                                            \n      } catch (err) {                                                                                                                                                                \n        console.error('Search Error:', err.message);                                                                                                                                 \n        await setOutput({                                                                                                                                                            \n          port: 'error',                                                                                                                                                             \n          data: { type: DataType.String, value: err.message }                                                                                                                        \n        });                                                                                                                                                                          \n      }                                                                                                                                                                           \n    }\n  };","language":"javascript","name":"My First Script"}}},"type":"script","groupId":"{#}YrQTccT","secrets":{"TAVILY_API_KEY":{"name":"TAVILY_API_KEY"}}},"{#}KNgBnpI":{"id":"{#}KNgBnpI","canvas":{"position":{"x":-6556,"y":-7053}},"children":[],"state":{"text":"Next steps:&#x20;\n\n* continue testing with other personas\n*\n\n","color":"#eac43e","size":{"width":300,"height":200},"locked":false},"type":"note"},"{#}b9L7wFM":{"id":"{#}b9L7wFM","canvas":{"position":{"x":1843,"y":504}},"children":[{"childId":"{#}9joQbTV","sourcePort":"{#}b9L7wFM_innerOutput_inner-input-input1","targetPort":"{#}9joQbTV_input_setValue"}],"state":{"canvasPosition":{"x":-177.77778248728055,"y":198.33849266737047},"name":"Discover Tools","description":"Provides access to the project's agent tools","inputs":[{"index":0,"label":"tools","name":"input1","type":[6],"position":{"x":304,"y":629}}],"outputs":[],"settings":[],"color":"#68bb6c","markdownHelp":"","protocolVersion":"2","type":"custom","canvasZoom":1},"type":"widgetGroup","groupId":"{#}gt2l79i"},"{#}9joQbTV":{"id":"{#}9joQbTV","canvas":{"position":{"x":517,"y":524}},"children":[],"state":{"name":"Settings.Scan _Tools","reactive":false,"lastConfiguration":{"controlType":"anything","controlSettings":{"value":null},"helpText":"Routes tool scanning events to all agent tools.","group":"Settings"}},"type":"globalVariable","groupId":"{#}b9L7wFM"},"{#}rXArruh":{"id":"{#}rXArruh","canvas":{"position":{"x":145,"y":173}},"children":[],"state":{"text":"# Discover Tools\n\nCopy this widget to every agent you create to allow them to access the project's tools.\n","color":"#a9b8c2","size":{"width":797,"height":200},"locked":true},"type":"note","groupId":"{#}b9L7wFM"},"{#}BezNwq7":{"id":"{#}BezNwq7","canvas":{"position":{"x":-4819,"y":-6411}},"children":[{"childId":"{#}lOgKjyb","sourcePort":"{#}BezNwq7_innerOutput_inner-input-input1-CDDpbo","targetPort":"{#}lOgKjyb_input_input"}],"state":{"description":"","inputs":[{"name":"input1-CDDpbo","label":"tools","type":[6],"index":0,"position":{"x":1767,"y":868}}],"outputs":[],"name":"Read Text File","type":"custom","color":"#4e3eff","canvasPosition":{"x":1181.094952008053,"y":181.94570995219453},"markdownHelp":"","settings":[],"protocolVersion":"2","canvasZoom":0.7590255602837391},"type":"widgetGroup"},"{#}lOgKjyb":{"id":"{#}lOgKjyb","canvas":{"position":{"x":2170.3304331452355,"y":900.0785941463063}},"children":[{"childId":"{#}T5w3RAN","sourcePort":"{#}lOgKjyb_output_arguments","targetPort":"{#}T5w3RAN_input_event"}],"state":{"dynamicInputs":{},"dynamicOutputs":{},"customState":{"name":"ReadFile","description":"Reads the text contents of a file in the project's directory","arguments":[{"name":"filePath","description":"The full path within the project’s directory where the file is located, without the leading ‘/’ (e.g., ‘folderA/innerFolder/file.md’). The file name must be included in the path.","dataType":"String","typeDefinition":"","typeDefinitionMode":"typescript","required":true}],"timeout":10},"variantId":"tool","service":{"name":"kemu.io.ai-agent","version":"1.8.2","title":"AI Agent","description":"Define AI agents and tools for automated workflows","processor":"js","widgetUI":true,"settingsUI":false,"eventEmitter":true,"ignoreParentEvents":false,"svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-102.48l-82.801-189.72c-6.4805-14.762-27.359-14.762-33.719 0l-82.801 189.72c-20.039 45.961-56.641 82.559-102.48 102.48l-190.08 82.922c-14.641 6.4805-14.762 27.238 0 33.719l193.44 85.441c45.719 20.281 82.199 57 102 103.08l80.039 186.12c6.3594 14.762 27.359 14.879 33.84 0l82.68-189.6c19.922-45.84 56.52-82.441 102.48-102.48l189.72-82.801c14.762-6.3594 14.762-27.238 0-33.719zm-210.84-6.9609c-3 6.7188-9.6016 10.801-16.559 10.801-2.3984 0-4.8008-0.48047-7.1992-1.4414-64.078-28.078-114.72-78.719-142.68-142.8-4.0781-9.1211 0.12109-19.801 9.2383-23.762 9.1211-3.9609 19.68 0.23828 23.762 9.3594 24.238 55.68 68.398 99.84 124.08 124.2 9.1211 3.9609 13.32 14.52 9.3594 23.641z\"/>\n <path d=\"m1113.1 322.08-109.56-47.762c-26.52-11.641-47.641-32.762-59.281-59.281l-47.762-109.56c-3.7188-8.5195-15.84-8.5195-19.559 0l-47.762 109.56c-11.641 26.52-32.762 47.641-59.281 59.281l-109.68 47.879c-8.5195 3.7188-8.5195 15.719-0.12109 19.441l111.72 49.32c26.398 11.762 47.52 33 58.922 59.52l46.32 107.64c3.6016 8.5195 15.719 8.5195 19.441 0l47.762-109.44c11.641-26.52 32.762-47.641 59.281-59.281l109.56-47.762c8.5195-3.7188 8.5195-15.84 0-19.559zm-149.28 15.84c-3.4805 5.6406-9.3594 8.6406-15.48 8.6406-3.1211 0-6.3594-0.83984-9.2383-2.5195-24.84-15.121-45.359-34.922-61.199-59.16-5.3984-8.3984-3-19.441 5.2812-24.961 8.2812-5.3984 19.441-3.1211 24.84 5.2812 12.961 19.68 29.641 35.762 49.68 48 8.5195 5.1602 11.281 16.199 6.1211 24.719z\"/>\n</svg>\n","color":"#42a5f5","mdHelp":"/docs/help/service.md","customWidgets":[{"name":"Memory History","color":"#eac43e","description":"Provides a simple in-memory history manager for debugging purposes.","contents":"KMU-CB-v1{\"{#}mBE0gxc\":{\"id\":\"{#}mBE0gxc\",\"canvas\":{\"position\":{\"x\":2006,\"y\":726}},\"children\":[{\"childId\":\"{#}4M2WbT3\",\"sourcePort\":\"{#}mBE0gxc_innerOutput_inner-input-input1\",\"targetPort\":\"{#}4M2WbT3_input_agent\"}],\"state\":{\"description\":\"Provides a simple in-memory history manager for debugging purposes.\",\"inputs\":[{\"index\":0,\"label\":\"agent\",\"name\":\"input1\",\"type\":[5],\"position\":{\"x\":519,\"y\":291}}],\"outputs\":[],\"name\":\"Memory History\",\"type\":\"custom\",\"color\":\"#eac43e\",\"icon\":\"database\",\"canvasPosition\":{\"x\":0,\"y\":0},\"markdownHelp\":\"\",\"settings\":[],\"protocolVersion\":\"2\"},\"type\":\"widgetGroup\"},\"{#}4M2WbT3\":{\"id\":\"{#}4M2WbT3\",\"canvas\":{\"position\":{\"x\":659,\"y\":341}},\"children\":[{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_getHistory\",\"targetPort\":\"{#}jCnteeA_input_read\"},{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_updateHistory\",\"targetPort\":\"{#}jCnteeA_input_update\"}],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{\"includeAttachments\":false,\"timeout\":60},\"variantId\":\"history\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"ver