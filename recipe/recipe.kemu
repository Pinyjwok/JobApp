023-20.586-21.375v-255.15c0-8.625-5.9609-15.676-13.273-15.676h-144.07c-7.3125 0-13.273 7.0508-13.273 15.676v255.15c0 10.352-10.539 21.375-20.586 21.375h-94.461c-7.3516 0-10.727 5.9609-11.812 8.5859-2.1758 4.9883-2.5859 12.414 2.5508 18.336l200.44 229.54c5.0234 5.7734 13.461 5.7383 18.414 0.039063l200.48-229.57c5.0508-5.9297 4.6367-13.391 2.4609-18.34z\"/>\n <path d=\"m384.68 298.57c13.727 0 24.898-9.7109 24.898-21.637v-159.56l-193.24 181.2z\"/>\n</svg>\n","color":"#4e3eff","inputs":[{"name":"path","type":1,"description":"The full path to the file to write"},{"name":"contents","type":12,"description":"The contents to write"},{"name":"write","type":6,"description":"Executes the write operation when this input is triggered","triggerPort":true}],"outputs":[{"name":"success","type":4,"description":"Whether the file was written successfully"}]},{"id":"file-to-text","name":"File To Text","description":"Converts a binary file to text using the specified encoding","svgIcon":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"23.298 16.64 439.97 473.219\" width=\"439.97px\" height=\"473.219px\">\n  <path d=\"M 136.998 229.735 C 139.146 232.955 142.365 234.029 145.584 234.029 C 148.807 234.029 152.026 232.955 154.173 229.735 L 186.373 186.801 C 189.593 182.506 188.52 174.993 184.227 171.774 C 179.934 168.552 172.419 169.627 169.2 173.92 L 156.32 191.093 L 156.32 115.952 C 156.32 109.512 160.612 105.219 167.054 105.219 L 199.254 105.219 C 205.694 105.219 209.988 100.926 209.988 94.485 C 209.988 88.045 205.694 83.751 199.254 83.751 L 167.054 83.751 C 148.807 83.751 134.852 97.704 134.852 115.952 L 134.852 191.093 L 121.973 173.92 C 118.751 169.627 111.237 168.552 106.945 171.774 C 102.651 174.993 101.577 182.506 104.799 186.801 L 136.998 229.735 Z M 454.715 281.257\" style=\"\" transform=\"matrix(1, 0, 0, 1, 1.1368683772161603e-13, 0)\"/>\n  <path d=\"M 257.168 294.967 L 257.168 450.881 C 257.168 472.968 240.278 489.859 218.19 489.859