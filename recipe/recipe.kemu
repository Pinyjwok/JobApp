3.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n","inputs":[{"name":"agent","description":"Connect to the agent","type":5}],"outputs":[{"name":"getHistory","description":"Invoked when the agent needs to retrieve the conversation history","type":5},{"name":"updateHistory","description":"Invoked when the agent needs to update the conversation history","type":5}],"color":"#eac43e"}],"publicationId":"kemu.io.ai-agent-osx-arm64-1.8.2","sessionId":1777586144,"internal":false}},"type":"hubService","secrets":{"OPENROUTER_API_KEY":{"name":"OPENROUTER_API_KEY","sharedAcrossInstances":true,"hubServiceName":"kemu.io.ai-agent"}},"groupId":"{#}nYXsJD8"},"{#}nAumrxX":{"id":"{#}nAumrxX","canvas":{"position":{"x":780,"y":602}},"children":[{"childId":"{#}5M0pCRE","sourcePort":"{#}nAumrxX_output_sessionHistoryOutput","targetPort":"{#}5M0pCRE_input_input"}],"state":{"pauseExecution":false,"autoPauseOnError":true,"version":2,"metadata":{"name":"Memory History","description":"Keeps the history messages in memory (this is intended for dev purposes only)"},"pages":{"main":{"code":"/**\n * Name: Memory History\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\n */\n\nconst sessions = {};\n\nconst getWidgetInputs = () => [\n  { name: 'read', type: DataType.JsonObj },\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\n];\n\nconst getWidgetOutputs = () => [\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\n];\n\nconst onParentEvent = async ({ targetPort, event }) => {\n  const inputData = event.data.value;\n\n  if (targetPort.name === 'read') {\n    const sessionId = inputData.sessionId;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'read' event missing 'sessionId' property.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\n\n  } else if (targetPort.name === 'update') {\n    const sessionId = inputData.sessionId;\n    const messagesToProcess = inputData.messages;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'update' event missing 'sessionId' property.\");\n      return;\n    }\n    if (messagesToProcess === undefined || messagesToProcess === null) {\n      console.error(\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    if (Array.isArray(messagesToProcess)) {\n      sessions[sessionId].messages.push(...messagesToProcess);\n    } else {\n      sessions[sessionId].messages.push(messagesToProcess);\n    }\n  }\n};","language":"javascript","name":"My First Script"}}},"type":"script","secrets":{},"groupId":"{#}nYXsJD8"},"{#}GReXksA":{"id":"{#}GReXksA","canvas":{"position":{"x":532,"y":218}},"children":[],"state":{"text":"# Agent Memory\n\nBasic in-memory history that allows the agent to remember chat history. This is a basic solution (make sure you instruct your agents to read and write a “memory” file using their available tools to persist progress to disk).\n","color":"#a9b8c2","size":{"width":917,"height":200},"locked":true},"type":"note","groupId":"{#}nYXsJD8"},"{#}kz1mPoB":{"id":"{#}kz1mPoB","canvas":{"position":{"x":1238.8172726076455,"y":1370.6042567302688}},"children":[{"childId":"{#}UZV18YN","sourcePort":"{#}kz1mPoB_output_out","targetPort":"{#}UZV18YN_input_abort"}],"state":{},"type":"play","groupId":"{#}WHcjeID"},"{#}RkQbmlu":{"id":"{#}RkQbmlu","canvas":{"position":{"x":1382.4786419411878,"y":1113.1137350282097}},"children":[{"childId":"{#}awBa5d7","sourcePort":"{#}RkQbmlu_output_out","targetPort