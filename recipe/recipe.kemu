2-40.805z\"/>\n <path d=\"m532.8 1046.4-24-3.6016c-33.602-7.1992-66 14.398-72 48-7.1992 33.602 14.398 66 48 72 9.6016 2.3984 20.398 3.6016 30 4.8008 2.3984 0 6 1.1992 9.6016 1.1992 30 0 56.398-21.602 60-52.801 4.7969-33.598-18.004-64.797-51.602-69.598z\"/>\n <path d=\"m321.6 955.2c-26.398-20.398-64.801-16.801-86.398 9.6016-20.398 26.398-16.801 64.801 9.6016 86.398 8.3984 6 15.602 12 24 18 10.801 7.1992 22.801 10.801 34.801 10.801 19.199 0 38.398-8.3984 50.398-26.398 19.199-27.602 13.199-66-14.398-85.199z\"/>\n <path d=\"m192 793.2c-14.398-31.199-50.398-44.398-81.602-30-31.199 14.398-44.398 50.398-30 81.602 4.8008 9.6016 8.3984 18 13.199 27.602 10.801 20.398 32.398 32.398 54 32.398 9.6016 0 19.199-2.3984 28.801-7.1992 30-15.602 40.801-52.801 25.199-82.801z\"/>\n <path d=\"m800.4 657.6-140.4-90v-223.2c0-33.602-27.602-61.199-61.199-61.199-33.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n", "inputs": [{"name": "agent", "description": "Connect to the agent", "type": 5}], "outputs": [{"name": "getHistory", "description": "Invoked when the agent needs to retrieve the conversation history", "type": 5}, {"name": "updateHistory", "description": "Invoked when the agent needs to update the conversation history", "type": 5}], "color": "#eac43e"}], "publicationId": "kemu.io.ai-agent-osx-arm64-1.8.2", "sessionId": 1777873834}}, "type": "hubService", "secrets": {"OPENROUTER_API_KEY": {"name": "OPENROUTER_API_KEY", "sharedAcrossInstances": true, "hubServiceName": "kemu.io.ai-agent"}}, "groupId": "{#}gKVI4qs"}, "{#}oAEGdYD": {"id": "{#}oAEGdYD", "canvas": {"position": {"x": 1051, "y": 424}}, "children": [{"childId": "{#}HEQcf9V", "sourcePort": "{#}oAEGdYD_output_sessionHistoryOutput", "targetPort": "{#}HEQcf9V_input_input"}], "state": {"pauseExecution": false, "autoPauseOnError": true, "version": 2, "metadata": {"name": "Memory History", "description": "Keeps the history messages in memory (this is intended for dev purposes only)"}, "pages": {"main": {"code": "/**\n * Name: Memory History\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\n */\n\nconst sessions = {};\n\nconst getWidgetInputs = () => [\n  { name: 'read', type: DataType.JsonObj },\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\n];\n\nconst getWidgetOutputs = () => [\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\n];\n\nconst onParentEvent = async ({ targetPort, event }) => {\n  const inputData = event.data.value;\n\n  if (targetPort.name === 'read') {\n    const sessionId = inputData.sessionId;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'read' event missing 'sessionId' property.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\n\n  } else if (targetPort.name === 'update') {\n    const sessionId = inputData.sessionId;\n    const messagesToProcess = inputData.messages;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'update' event missing 'sessionId' property.\");\n      return;\n    }\n    if (messagesToProcess === undefined || messagesToProcess === null) {\n      console.error(\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    if (Array.isArray(messagesToProcess)) {\n      sessions[sessionId].messages.push(...messagesToProcess);\n    } else {\n      sessions[sessionId].messages.push(messagesToProcess);\n    }\n  }\n};", "language": "javascript", "name": "My First Script"}}}, "type": "script", "secrets": {}, "groupId": "{#}gKVI4qs"}, "{#}up4H39j": {"id": "{#}up4H39j", "canvas": {"position": {"x": 235, "y": 178}}, "children": [], "state": {"text": "# Agent Memory\n\nBasic in-memory history that allows the agent to remember chat history. This is a basic solution (make sure you instruct your agents to read and write a \u201cmemory\u201d file using their available tools to persist progress to disk).\n", "color": "#a9b8c2", "size": {"width": 917, "height": 200}, "locked": true}, "type": "note", "groupId": "{#}gKVI4qs"}, "{#}rV10E3c": {"id": "{#}rV10E3c", "canvas": {"position": {"x": 1946, "y": 616}}, "children": [{"childId": "{#}3Xqmrv4", "sourcePort": "{#}rV10E3c_innerOutput_inner-input-input1", "targetPort": "{#}3Xqmrv4_input_agent"}], "state": {"description": "Provides a simple in-memory history manager for debugging purposes.", "inputs": [{"index": 0, "label": "agent", "name": "input1", "type": [5], "position": {"x": 242, "y": 477}}], "outputs": [], "name": "Memory History", "type": "custom", "color": "#eac43e", "icon": "database", "canvasPosition": {"x": -206.11046080613005, "y": -207.19553594529202}, "markdownHelp": "", "settings": [], "protocolVersion": "2", "canvasZoom": 1}, "type": "widgetGroup", "groupId": "{#}nRquBb7"}, "{#}3Xqmrv4": {"id": "{#}3Xqmrv4", "canvas": {"position": {"x": 1239, "y": 854}}, "children": [{"childId": "{#}OkNH0TE", "sourcePort": "{#}3Xqmrv4_output_getHistory", "targetPort": "{#}OkNH0TE_input_read"}, {"childId": "{#}OkNH0TE", "sourcePort": "{#}3Xqmrv4_output_updateHistory", "targetPort": "{#}OkNH0TE_input_update"}], "state": {"dynamicInputs": {}, "dynamicOutputs": {}, "customState": {"includeAttachments": false, "timeout": 10}, "variantId": "history", "service": {"name": "kemu.io.ai-agent", "version": "1.8.2", "title": "AI Agent", "description": "Define AI agents and tools for automated workflows", "processor": "js", "widgetUI": true, "settingsUI": false, "eventEmitter": true, "ignoreParentEvents": false, "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"