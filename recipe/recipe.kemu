": "", "settings": [], "protocolVersion": "2", "canvasZoom": 1}, "type": "widgetGroup", "groupId": "{#}nRquBb7"}, "{#}4QdRpjA": {"id": "{#}4QdRpjA", "canvas": {"position": {"x": 515, "y": 608}}, "children": [{"childId": "{#}03A8Axd", "sourcePort": "{#}4QdRpjA_output_value", "targetPort": "{#}03A8Axd_innerInput_inner-output-output1"}], "state": {"name": "Settings.Abort_All_Processing", "reactive": true, "lastConfiguration": {"controlType": "anything", "controlSettings": {"value": null}, "helpText": "Linked to the 'abort' ports of all agents", "group": "Settings"}}, "type": "globalVariable", "groupId": "{#}03A8Axd"}, "{#}OLYiJ8M": {"id": "{#}OLYiJ8M", "canvas": {"position": {"x": 317, "y": 227}}, "children": [], "state": {"text": "# Abort Processing\n\nReacts to 'abort' events produced by the chat interface. Copy this widget for every agent you create and link it to the 'abort' input port.\n", "color": "#a9b8c2", "size": {"width": 631, "height": 200}, "locked": true}, "type": "note", "groupId": "{#}03A8Axd"}, "{#}MbO7RQk": {"id": "{#}MbO7RQk", "canvas": {"position": {"x": -6112, "y": -7146}}, "children": [], "state": {"text": "All 6 agents with KEMU WriteFile calls are now guarded (PB, SC, HF, CF, SR, IC). The\nstray workspacecv\\_assembly\\_state.json/ directory also needs cleanup before next\nrun.\n", "color": "#eac43e", "size": {"width": 719, "height": 271}, "locked": false}, "type": "note"}, "{#}Mz09u3E": {"id": "{#}Mz09u3E", "canvas": {"position": {"x": -4831, "y": -6212}}, "children": [{"childId": "{#}Eg6Xaxp", "sourcePort": "{#}Mz09u3E_innerOutput_inner-input-input1-CDDpbo", "targetPort": "{#}Eg6Xaxp_input_input"}], "state": {"description": "", "inputs": [{"name": "input1-CDDpbo", "label": "tools", "type": [6], "index": 0, "position": {"x": 1920, "y": 898}}], "outputs": [], "name": "ResearchCompany", "type": "custom", "color": "#42a5f5", "icon": "search", "canvasPosition": {"x": 1352.935329587277, "y": 251.9173479400422}, "markdownHelp": "", "settings": [], "protocolVersion": "2", "canvasZoom": 0.6239125267098532}, "type": "widgetGroup"}, "{#}Eg6Xaxp": {"id": "{#}Eg6Xaxp", "canvas": {"position": {"x": 2170.3304331452355, "y": 900.0785941463063}}, "children": [{"childId": "{#}i76WJy4", "sourcePort": "{#}Eg6Xaxp_output_arguments", "targetPort": "{#}i76WJy4_input_event"}], "state": {"dynamicInputs": {}, "dynamicOutputs": {}, "customState": {"name": "ResearchCompany", "description": "Researches company specified in PD", "arguments": [{"name": "companyName", "description": "Company to research", "dataType": "String", "typeDefinition": "", "typeDefinitionMode": "typescript", "required": true}, {"name": "positionTitle", "description": "Position to target CV for\n", "dataType": "String", "typeDefinition": "", "typeDefinitionMode": "typescript", "required": true}, {"name": "sector", "description": "Targeted companies sector for research\n", "dataType": "String", "typeDefinition": "", "typeDefinitionMode": "typescript", "required": true}], "timeout": 10}, "variantId": "tool", "service": {"name": "kemu.io.ai-agent", "version": "1.8.2", "title": "AI Agent", "description": "Define AI agents and tools for automated workflows", "processor": "js", "widgetUI": true, "settingsUI": false, "eventEmitter": true, "ignoreParentEvents": false, "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-102.48l-82.801-189.72c-6.4805-14.762-27.359-14.762-33.719 0l-82.801 189.72c-20.039 45.961-56.641 82.559-102.48 102.48l-190.08 82.922c-14.641 6.4805-14.762 27.238 0 33.719l193.44 85.441c45.719 20.281 82.199 57 102 103.08l80.039 186.12c6.3594 14.762 27.359 14.879 33.84 0l82.68-189.6c19.922-45.84 56.52-82.441 102.48-102.48l189.72-82.801c14.762-6.3594 14.762-27.238 0-33.719zm-210.84-6.9609c-3 6.7188-9.6016 10.801-16.559 10.801-2.3984 0-4.8008-0.48047-7.1992-1.441