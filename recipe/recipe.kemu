": "Manage conversation history and session storage for AI agents", "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m1003.2 198c-216-216-560.4-220.8-784.8-19.199l-60-60c-19.199-19.199-52.801-9.6016-58.801 16.801l-68.398 280.8c-6 25.199 16.801 49.199 43.199 43.199l280.8-68.398c26.398-6 36-39.602 16.801-58.801l-66-66c176.4-153.6 444-148.8 612 19.199 174 174 174 459.6-1.1992 634.8l-16.801 15.602c-25.199 22.801-26.398 61.199-4.8008 86.398 12 13.199 28.801 20.398 45.602 20.398 14.398 0 28.801-4.8008 40.801-15.602 7.1992-6 14.398-13.199 20.398-20.398 223.2-223.2 223.2-585.6 1.1992-808.8z\"/>\n <path d=\"m739.2 1028.4-22.801 7.1992c-32.398 8.3984-51.602 42-43.199 75.602 7.1992 27.602 32.398 45.602 58.801 45.602 4.8008 0 10.801-1.1992 15.602-2.3984 9.6016-2.3984 19.199-6 28.801-8.3984 32.398-10.801 49.199-45.602 38.398-76.801-8.4023-33.602-43.199-51.602-75.602-40.805z\"/>\n <path d=\"m532.8 1046.4-24-3.6016c-33.602-7.1992-66 14.398-72 48-7.1992 33.602 14.398 66 48 72 9.6016 2.3984 20.398 3.6016 30 4.8008 2.3984 0 6 1.1992 9.6016 1.1992 30 0 56.398-21.602 60-52.801 4.7969-33.598-18.004-64.797-51.602-69.598z\"/>\n <path d=\"m321.6 955.2c-26.398-20.398-64.801-16.801-86.398 9.6016-20.398 26.398-16.801 64.801 9.6016 86.398 8.3984 6 15.602 12 24 18 10.801 7.1992 22.801 10.801 34.801 10.801 19.199 0 38.398-8.3984 50.398-26.398 19.199-27.602 13.199-66-14.398-85.199z\"/>\n <path d=\"m192 793.2c-14.398-31.199-50.398-44.398-81.602-30-31.199 14.398-44.398 50.398-30 81.602 4.8008 9.6016 8.3984 18 13.199 27.602 10.801 20.398 32.398 32.398 54 32.398 9.6016 0 19.199-2.3984 28.801-7.1992 30-15.602 40.801-52.801 25.199-82.801z\"/>\n <path d=\"m800.4 657.6-140.4-90v-223.2c0-33.602-27.602-61.199-61.199-61.199-33.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n", "inputs": [{"name": "agent", "description": "Connect to the agent", "type": 5}], "outputs": [{"name": "getHistory", "description": "Invoked when the agent needs to retrieve the conversation history", "type": 5}, {"name": "updateHistory", "description": "Invoked when the agent needs to update the conversation history", "type": 5}], "color": "#eac43e"}], "publicationId": "kemu.io.ai-agent-osx-arm64-1.8.2", "sessionId": 1777873834}}, "type": "hubService", "secrets": {"OPENROUTER_API_KEY": {"name": "OPENROUTER_API_KEY", "sharedAcrossInstances": true, "hubServiceName": "kemu.io.ai-agent"}}, "disabled": false, "groupId": "{#}Mz09u3E"}, "{#}i76WJy4": {"id": "{#}i76WJy4", "canvas": {"position": {"x": 2331, "y": 882}}, "children": [{"childId": "{#}qzAL6fR", "sourcePort": "{#}i76WJy4_output_error", "targetPort": "{#}qzAL6fR_input_input"}, {"childId": "{#}QSNEMos", "sourcePort": "{#}i76WJy4_output_event", "targetPort": "{#}QSNEMos_input_event"}], "state": {}, "type": "rescue", "groupId": "{#}Mz09u3E"}, "{#}qzAL6fR": {"id": "{#}qzAL6fR", "canvas": {"position": {"x": 2632.3304331452355, "y": 1070.0785941463064}}, "children": [{"childId": "{#}030krFJ", "sourcePort": "{#}qzAL6fR_output_text", "targetPort": "{#}030krFJ_input_input"}], "state": {"text": "Invalid Tool Arguments: {{input.error.message}}", "format": "Text", "size": {"width": 461, "height": 100}}, "type": "templateString", "groupId": "{#}Mz09u3E"}, "{#}j0f3yP1": {"id": "{#}j0f3yP1", "canvas": {"position": {"x": 3210, "y": 1220}}, "children": [{"childId": "{#}030krFJ", "sourcePort": "{#}j0f3yP1_output_text", "targetPort": "{#}030krFJ_input_input"}], "state": {"text": "Failed to conduct research: {{input.error.message}}", "format": "Text", "size": {"width": 220, "height": 135}}, "type": "templateString", "groupId": "{#}Mz09u3E"}, "{#}d83Vxc8": {"id": "{#}d83Vxc8", "canvas": {"position": {"x": 3359, "y": 671}}, "children": [{"childId": "{#}030krFJ", "sourcePort": "{#}d83Vxc8_output_summary", "targetPort": "{#}030krFJ_input_input"}, {"childId": "{#}j0f3yP1", "sourcePort": "{#}d83Vxc8_output_error", "targetPort": "{#}j0f3yP1_input_input"}], "state": {"pauseExecution": false, "autoPauseOnError": true, "version": 2, "metadata": {"name": "Tavily Search Tool", "description": "Performs a token-efficient search tailored for AI agents."}, "pages": {"main": {"code": "  /**                                                                                                   \n   * Name: Tavily Search Tool                                                                           \n   * Description: Performs a token-efficient search tailored for AI agents.                             \n   */\n                                                                                                        \n  const getWidgetInputs = () => [                                                                                                                                                    \n    { name: 'query', type: DataType.String },                                                                                                                                        \n    { name: 'sector', type: DataType.String }                                                                                                                                        \n  ];                                                                                                                                                                                 \n                                                                                                                                                                                     \n  const getWidgetOutputs = () => [                                                                                                                                                   \n    { name: 'summary', type: DataType.String },                                                                                                                                      \n    { name: 'error', type: DataType.String }                                                                                                                                         \n  ];                                                                                                                                                                                 \n                                                                                                                                                                                     \n  Kemu.secrets.requestAccess('TAVILY_API_KEY');                                                                                                                                      \n                                                                                                                                                                                     \n  let storedSector = \"\";                                                                                                                                                             \n                                                                                                                                                                                     \n  const onParentEvent = async ({ targetPort, event }) => {                                                                                                                           \n                                                                                                                                                                                     \n    if (targetPort.name === 'sector' && event.data.value) {                                                                                                                          \n      storedSector = event.data.value;                                                                                                                                               \n      return;                                                                                                                                                                        \n    }                                                                                                                                                                                \n                                                                                                                                                                                     \n    if (targetPort.name === 'query' && event.data.value) {                                                                                                                           \n      try {                                                                                                                                                                          \n        const searchQuery = event.data.value;                                                                                                                                        \n        const secrets = await Kemu.secrets.read(['TAVILY_API_KEY']);                                                                                                                 \n        const apiKey = secrets['TAVILY_API_KEY'] || process.env.TAVILY_API_KEY;                                                                                                                                    \n                                                                                                                                                                                     \n        const response = await fetch('https://api.tavily.com/search', {                                                                                                              \n          method: 'POST',                                                                                                                                                            \n          headers: { 'Content-Type': 'application/json' },                                                                                                                           \n          body: JSON.stringify({                                                                                                                                                     \n            api_key: apiKey,                                                                                                                                                         \n            query: searchQuery,                                                                                                                                                      \n            search_depth: \"advanced\",                                                                                                                                                \n            include_answer: true,                                                                                                                                                    \n            max_results: 10,                                                                                                                                                         \n            include_domains: [                                                                                                                                                       \n              \"linkedin.com\",                                                                                                                                                        \n              \"glassdoor.com\",                                                                                                                                                       \n              \"glassdoor.com.au\",                                                                                                                                                    \n              \"indeed.com\",                                                                                                                                                          \n              \"seek.com.au\"                                                                                                                                                          \n            ]                                                                                                                                                                        \n          })                                                                                                                                                                         \n        });                                                                                                                                                                          \n                                                                                                                                                                                     \n        const data = await response.json();                                                                                                                                       \n\n        if (data && data.results) {\n          const aiAnswer = data.answer ? `AI Summary: ${data.answer}\\n\\n` : '';                                                                                                      \n          let finalContext = `${aiAnswer}Sources:\\n`;                                                                                                                                \n                                                                                                                                                                                     \n          data.results.forEach((item, i) => {                                                                                                                                        \n            finalContext += `[${i + 1}] ${item.title}\\n   URL: ${item.url}\\n   ${item.content}\\n\\n`;                                                                                 \n          });                                                                                                                                                                        \n                                                                                                                                                                                     \n          await setOutput({                                                                                                                                                          \n            port: 'summary',                                                                                                                                                         \n            data: { type: DataType.String, value: finalContext }                                                                                                                     \n          });                                                                                                                                                                        \n        } else {                                                                                                                                                                     \n          throw new Error(\"Tavily returned an empty or invalid response\");                                                                                                           \n        }                                                                                                                                                                            \n      } catch (err) {                                                                                                                                                                \n        console.error('Search Error:', err.message);                                                                                                                                 \n        await setOutput({                                                                                                                                                            \n          port: 'error',                                                                                                                                                             \n          data: { type: DataType.String, value: err.message }                                                                                                                        \n        });                                                                                                                                                                          \n      }                                                                                                                                                                           \n    }\n  };", "language": "javascript", "name": "My First Script"}}}, "type": "script", "groupId": "{#}Mz09u3E", "secrets": {"TAVILY_API_KEY": {"name": "TAVILY_API_KEY"}}}, "{#}5yuXUAj": {"id": "{#}5yuXUAj", "canvas": {"position": {"x": -6556, "y": -7053}}, "children": [], "state": {"text": "Next steps:&#x20;\n\n* continue testing with other personas\n*\n\n", "color": "#eac43e", "size": {"width": 300, "height": 200}, "locked": false}, "type": "note"}, "{#}T7geP01": {"id": "{#}T7geP01", "canvas": {"position": {"x": 1843, "y": 504}}, "children": [{"childId": "{#}H3h6l7X", "sourcePort": "{#}T7geP01_innerOutput_inner-in