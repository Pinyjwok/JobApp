z\"/>\n <path d=\"m321.6 955.2c-26.398-20.398-64.801-16.801-86.398 9.6016-20.398 26.398-16.801 64.801 9.6016 86.398 8.3984 6 15.602 12 24 18 10.801 7.1992 22.801 10.801 34.801 10.801 19.199 0 38.398-8.3984 50.398-26.398 19.199-27.602 13.199-66-14.398-85.199z\"/>\n <path d=\"m192 793.2c-14.398-31.199-50.398-44.398-81.602-30-31.199 14.398-44.398 50.398-30 81.602 4.8008 9.6016 8.3984 18 13.199 27.602 10.801 20.398 32.398 32.398 54 32.398 9.6016 0 19.199-2.3984 28.801-7.1992 30-15.602 40.801-52.801 25.199-82.801z\"/>\n <path d=\"m800.4 657.6-140.4-90v-223.2c0-33.602-27.602-61.199-61.199-61.199-33.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n", "inputs": [{"name": "agent", "description": "Connect to the agent", "type": 5}], "outputs": [{"name": "getHistory", "description": "Invoked when the agent needs to retrieve the conversation history", "type": 5}, {"name": "updateHistory", "description": "Invoked when the agent needs to update the conversation history", "type": 5}], "color": "#eac43e"}], "publicationId": "kemu.io.ai-agent-osx-arm64-1.8.2", "sessionId": 1777873834}}, "type": "hubService", "secrets": {"OPENROUTER_API_KEY": {"name": "OPENROUTER_API_KEY", "sharedAcrossInstances": true, "hubServiceName": "kemu.io.ai-agent"}}, "disabled": false, "groupId": "{#}wy1d83F"}, "{#}3aFShnB": {"id": "{#}3aFShnB", "canvas": {"position": {"x": 2331, "y": 882}}, "children": [{"childId": "{#}IsTcJon", "sourcePort": "{#}3aFShnB_output_error", "targetPort": "{#}IsTcJon_input_input"}, {"childId": "{#}mdhHCIF", "sourcePort": "{#}3aFShnB_output_event", "targetPort": "{#}mdhHCIF_input_event"}], "state": {}, "type": "rescue", "groupId": "{#}wy1d83F"}, "{#}IsTcJon": {"id": "{#}IsTcJon", "canvas": {"position": {"x": 2632.3304331452355, "y": 1070.0785941463064}}, "children": [{"childId": "{#}Hsx2A4C", "sourcePort": "{#}IsTcJon_output_text", "targetPort": "{#}Hsx2A4C_input_input"}], "state": {"text": "Invalid Tool Arguments: {{input.error.message}}", "format": "Text", "size": {"width": 461, "height": 100}}, "type": "templateString", "groupId": "{#}wy1d83F"}, "{#}8jUPzSG": {"id": "{#}8jUPzSG", "canvas": {"position": {"x": 3210, "y": 1220}}, "children": [{"childId": "{#}Hsx2A4C", "sourcePort": "{#}8jUPzSG_output_text", "targetPort": "{#}Hsx2A4C_input_input"}], "state": {"text": "Failed to conduct research: {{input.error.message}}", "format": "Text", "size": {"width": 220, "height": 135}}, "type": "templateString", "groupId": "{#}wy1d83F"}, "{#}GxdueBf": {"id": "{#}GxdueBf", "canvas": {"position": {"x": 3359, "y": 670}}, "children": [{"childId": "{#}Hsx2A4C", "sourcePort": "{#}GxdueBf_output_summary", "targetPort": "{#}Hsx2A4C_input_input"}, {"childId": "{#}8jUPzSG", "sourcePort": "{#}GxdueBf_output_error", "targetPort": "{#}8jUPzSG_input_input"}], "state": {"pauseExecution": false, "autoPauseOnError": true, "version": 2, "metadata": {"name": "Tavily Search Tool", "description": "Performs a token-efficient search tailored for AI agents."}, "pages": {"main": {"code": "  /**                                                                                                   \n   * Name: Tavily Search Tool                                                                           \n   * Description: Performs a token-efficient search tailored for AI agents.                             \n   */\n                                                                                                        \nconst getWidgetInputs = () => [                                                                                                                                                    \n    { name: 'query', type: DataType.String },                                                                                                                                        \n    { name: 'sector', type: DataType.String }                                                                                                                                        \n  ];                                                                                                                                                                                 \n                                                                                                                                                                                     \n  const getWidgetOutputs = () => [                                                                                                                                                \n    { name: 'summary', type: DataType.String },                                                                                                                                      \n    { name: 'error', type: DataType.String }                                                                                                                                         \n  ];                                                                                                                                                                                 \n                                                                                                                                                                                     \n  Kemu.secrets.requestAccess('TAVILY_API_KEY');                                                                                                                                      \n                                                                                                                                                                                     \n  let storedSector = \"\";                                                                                                                                                             \n                                                                                                                                                                                     \n  const onParentEvent = async ({ targetPort, event }) => {                                                                                                                           \n                                                                                                                                                                                     \n    if (targetPort.name === 'sector' && event.data.value) {                                                                                                                       \n      storedSector = event.data.value;\n      return;\n    }                                                                                                                                                                                \n                                                                                                                                                                                     \n    if (targetPort.name === 'query' && event.data.value) {                                                                                                                           \n      try {                                                                                                                                                                          \n        const baseQuery = event.data.value;                                                                                                                                          \n        const secrets = await Kemu.secrets.read(['TAVILY_API_KEY']);                                                                                                                 \n        const apiKey = secrets['TAVILY_API_KEY'] || process.env.TAVILY_API_KEY;                                                                                                                                    \n                                                                                                                                                                                     \n        const isAcademic = /university|college|institute|school|research|faculty|academia/i.test(storedSector);                                                                      \n                                                                                                                                                                                     \n        const keywords = isAcademic                                                                                                                                                  \n          ? \"research culture supervision expectations publication workload academic interview panel grant environment collegial HDR\"                                                \n          : \"workplace culture career progression onboarding entry level training interview format probation team structure fair work\";                                              \n                                                                                                                                                                                     \n        const fullQuery = `${baseQuery} ${keywords}`;                                                                                                                                \n                                                                                                                                                                                     \n        const response = await fetch('https://api.tavily.com/search', {                                                                                                              \n          method: 'POST',                                                                                                                                                            \n          headers: { 'Content-Type': 'application/json' },                                                                                                                        \n          body: JSON.stringify({                                                                                                                                                     \n            api_key: apiKey,                                                                                                                                                         \n            query: fullQuery,                                                                                                                                                        \n            search_depth: \"advanced\",                                                                                                                                                \n            include_answer: true,                                                                                                                                                    \n            max_results: 10,                                                                                                                                                      \n            exclude_domains: [\n              \"linkedin.com\",                                                                                                                                                        \n              \"glassdoor.com\",                                                                                                                                                       \n              \"glassdoor.com.au\"                                                                                                                                                     \n            ]                                                                                                                                                                        \n          })                                                                                                                                                                         \n        });                                                                                                                                                                       \n\n        const data = await response.json();\n                                                                                                                                                                                     \n        if (data && data.results) {                                                                                                                                                  \n          const aiAnswer = data.answer ? `AI Summary: ${data.answer}\\n\\n` : '';                                                                                                      \n          let finalContext = `${aiAnswer}Sources:\\n`;                                                                                                                                \n                                                                                                                                                                                     \n          data.results.forEach((item, i) => {                                                                                                                                        \n            finalContext += `[${i + 1}] ${item.title}\\n   URL: ${item.url}\\n   ${item.content}\\n\\n`;                                                                                 \n          });                                                                                                                                                                        \n                                                                                                                                                                                     \n          await setOutput({                                                                                                                                                       \n            port: 'summary',                                                                                                                                                         \n            data: { type: DataType.String, value: finalContext }                                                                                                                     \n          });                                                                                                                                                                        \n        } else {                                                                                                                                                                     \n          throw new Error(\"Tavily returned an empty or invalid response\");                                                                                                           \n        }                                                                                                                                                                         \n      } catch (err) {\n        console.error('Search Error:', err.message);                                                                                                                                 \n        await setOutput({                                                                                                                                                            \n          port: 'error',                                                                                                                                                             \n          data: { type: DataType.String, value: err.message }                                                                                                                        \n        });                                                                                                                                                                          \n      }                                                                                                                                                                           \n    }\n  };", "language": "javascript", "name": "My First Script"}}}, "type": "script", "groupId": "{#}wy1d83F", "secrets": {"TAVILY_API_KEY": {"name": "TAVILY_API_KEY"}}}, "{#}vKKbfWN": {"id": "{#}vKKbfWN", "canvas": {"position": {"x": 2757, "y": 532}}, "children": [{"childId": "{#}GxdueBf", "sourcePort": "{#}vKKbfWN_output_text", "targetPort": "{#}GxdueBf_input_sector"}], "state": {"text": "{{{input.sector}}}", "format": "Text"}, "type": "templateString", "groupId": "{#}wy1d83F"}, "{#}mdhHCIF": {"id": "{#}mdhHCIF", "canvas": {"position": {"x": 2442, "y": 820}}, "children": [{"childId": "{#}xvqEhuR", "sourcePort": "{#}mdhHCIF_output_1", "targetPort": "{#}xvqEhuR_input_input"}, {"childId": "{#}vKKbfWN", "sourcePort": "{#}mdhHCIF_output_2", "targetPort": "{#}vKKbfWN_input_input"}], "state": {"outputPortCount": 3}, "type": "sequence", "groupId": "{#}wy1d83F"}, "{#}aPzR9LZ": {"id": "{#}aPzR9LZ", "canvas": {"position": {"x": -5823, "y": -6591}}, "children": [{"childId": "{#}sugzMwP", "sourcePort": "{#}aPzR9LZ_output_output", "targetPort": "{#}sugzMwP_input_outer-input-config-NPd1HB"}], "state": {"inputName": "extractor_input"}, "type": "input"}, "{#}kLcTF6t": {"id": "{#}kLcTF6t", "canvas": {"position": {"x": -5782, "y": -6044}}, "children": [{"childId": "{#}fiUdbWI", "sourcePort": "{#}kLcTF6t_output_output", "targetPort": "{#}fiUdbWI_input_outer-input-config-NPd1HB"}], "state": {"inputName": "a