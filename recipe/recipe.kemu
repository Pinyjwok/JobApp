"includeAttachments\":false,\"timeout\":60},\"variantId\":\"history\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40a