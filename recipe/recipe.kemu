n or history retrieval","svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m645.28 600c0-12.516-5.0625-23.812-13.266-32.016-8.1562-8.2031-19.5-13.266-32.016-13.266s-23.812 5.0625-32.016 13.266c-8.2031 8.1562-13.266 19.5-13.266 32.016 0 12.469 5.0625 23.812 13.266 32.016 8.1562 8.2031 19.5 13.266 32.016 13.266s23.812-5.0625 32.016-13.266c8.2031-8.1562 13.266-19.5 13.266-32.016zm291.84 37.453c-0.23438 0.84375-86.812 289.13-417.14 310.13v-58.219h-0.046875c0-4.7344-1.2188-9.6094-3.7969-14.016-7.7344-13.078-24.609-17.438-37.688-9.7031l-227.95 135.37c-3.9375 2.25-7.4062 5.625-9.8906 9.8438-7.7344 13.078-3.375 29.953 9.7031 37.641l226.64 134.63c4.4062 3 9.75 4.7812 15.516 4.7812 15.234 0 27.562-12.328 27.562-27.562v-59.719c61.125-8.7656 151.6-31.031 238.13-87.703 99.375-65.062 193.4-174.89 231.89-360.24 3.8438-14.203-4.2188-29.062-18.375-33.469-14.531-4.5-29.906 3.6094-34.453 18.094zm-674.34-74.906c0.23438-0.84375 86.812-289.13 417.14-310.13v58.219h0.046875c0 4.7344 1.2188 9.6094 3.7969 14.016 7.7344 13.078 24.609 17.438 37.688 9.7031l227.95-135.37c3.9375-2.25 7.4062-5.625 9.8906-9.8438 7.7344-13.078 3.375-29.953-9.7031-37.641l-226.64-134.63c-4.4062-3.0469-9.75-4.7812-15.516-4.7812-15.234 0-27.562 12.328-27.562 27.562v59.719c-61.125 8.7656-151.6 31.031-238.13 87.703-99.375 65.062-193.4 174.89-231.89 360.24-3.8438 14.203 4.2188 29.062 18.375 33.469 14.531 4.5 29.906-3.6094 34.453-18.094zm266.16-33.516c18.188-18.188 43.266-29.391 71.016-29.391 27.703 0 52.828 11.25 71.016 29.391 18.188 18.188 29.391 43.266 29.391 71.016 0 27.703-11.25 52.828-29.391 71.016-18.188 18.188-43.266 29.391-71.016 29.391-27.703 0-52.828-11.25-71.016-29.391-18.188-18.188-29.391-43.266-29.391-71.016 0-27.703 11.25-52.828 29.391-71.016zm293.91 8.7227c11.109-8.9531 13.453-24.844 5.7188-36.562l-29.531-51.141c-6.9844-12.141-21.844-16.922-34.406-11.625l-41.672 16.031c-8.62