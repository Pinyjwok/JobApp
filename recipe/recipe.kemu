 current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"sv