"# Abort Processing\n\nReacts to 'abort' events produced by the chat interface. Copy this widget for every agent you create and link it to the 'abort' input port.\n", "color": "#a9b8c2", "size": {"width": 631, "height": 200}, "locked": true}, "type": "note", "groupId": "{#}HizYWTL"}, "{#}Bil6I7y": {"id": "{#}Bil6I7y", "canvas": {"position": {"x": 2314, "y": 676}}, "children": [{"childId": "{#}uWSKWWa", "sourcePort": "{#}Bil6I7y_innerOutput_inner-input-input1", "targetPort": "{#}uWSKWWa_input_agent"}], "state": {"description": "Provides a simple in-memory history manager for debugging purposes.", "inputs": [{"index": 0, "label": "agent", "name": "input1", "type": [5], "position": {"x": 291, "y": 501}}], "outputs": [], "name": "Memory History", "type": "custom", "color": "#eac43e", "icon": "database", "canvasPosition": {"x": 135.91742310440168, "y": -43.48152454839192}, "markdownHelp": "", "settings": [], "protocolVersion": "2", "canvasZoom": 0.7350394121653119}, "type": "widgetGroup", "groupId": "{#}vVbLLU4"}, "{#}uWSKWWa": {"id": "{#}uWSKWWa", "canvas": {"position": {"x": -100, "y": 24}}, "children": [{"childId": "{#}k1U2Hne", "sourcePort": "{#}uWSKWWa_output_getHistory", "targetPort": "{#}k1U2Hne_input_read"}, {"childId": "{#}k1U2Hne", "sourcePort": "{#}uWSKWWa_output_updateHistory", "targetPort": "{#}k1U2Hne_input_update"}], "state": {"dynamicInputs": {}, "dynamicOutputs": {}, "customState": {"includeAttachments": false, "timeout": 10}, "variantId": "history", "service": {"name": "kemu.io.ai-agent", "version": "1.8.2", "title": "AI Agent", "description": "Define AI agents and tools for automated workflows", "processor": "js", "widgetUI": true, "settingsUI": false, "eventEmitter": true, "ignoreParentEvents": false, "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-10