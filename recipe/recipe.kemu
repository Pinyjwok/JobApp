ent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"secrets\":{\"OPENROUTER_API_KEY\":{\"name\":\"OPENROUTER_API_KEY\",\"hubServiceName\":\"kemu.io.ai-agent\"}},\"groupId\":\"{#}mBE0gxc\"},\"{#}jCnteeA\":{\"id\":\"{#}jCnteeA\",\"canvas\":{\"position\":{\"x\":948,\"y\":397}},\"children\":[{\"childId\":\"{#}a5vxU9Y\",\"sourcePort\":\"{#}jCnteeA_output_sessionHistoryOutput\",\"targetPort\":\"{#}a5vxU9Y_input_input\"}],\"state\":{\"pauseExecution\":false,\"autoPauseOnError\":true,\"version\":2,\"metadata\":{\"name\":\"Memory History\",\"description\":\"Keeps the history messages in memory (this is intended for dev purposes only)\"},\"pages\":{\"main\":{\"code\":\"/**\\n * Name: Memory History\\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\\n */\\n\\nconst sessions = {};\\n\\nconst getWidgetInputs = () => [\\n  { name: 'read', type: DataType.JsonObj },\\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\\n];\\n\\nconst getWidgetOutputs = () => [\\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\\n];\\n\\nconst onParentEvent = async ({ targetPort, event }) => {\\n  const inputData = event.data.value;\\n\\n  if (targetPort.name === 'read') {\\n    const sessionId = inputData.sessionId;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'read' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\\n\\n  } else if (targetPort.name === 'update') {\\n    const sessionId = inputData.sessionId;\\n    const messagesToProcess = inputData.messages;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'update' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n    if (messagesToProcess === undefined || messagesToProcess === null) {\\n      console.error(\\\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    if (Array.isArray(messagesToProcess)) {\\n      sessions[sessionId].messages.push(...messagesToProcess);\\n    } else {\\n      sessions[sessionId].messages.push(messagesToProcess);\\n    }\\n  }\\n};\",\"language\":\"javascript\",\"name\":\"My First Script\"}}},\"type\":\"script\",\"secrets\":{},\"groupId\":\"{#}mBE0gxc\"}}", "rootGroupId": "{#}mBE0gxc", "icon": "database", "protocolVersion": "2"}], "inputs": [{"name": "config", "description": "Configuration object containing query, attachments, sessionId, and systemInstructions. Can also be a string to be used as query or a boolean to trigger processing.", "type": [5, 4, 1, 6]}, {"name": "abort", "description": "Abort current query signal", "type": 6}], "outputs": [{"name": "tools", "type": 5}, {"name": "history", "type": 5}, {"name": "json", "type": 5}, {"name": "text", "type": 1}, {"name": "stream", "type": 1}, {"name": "reasoning", "description": "Reasoning output from models that support extended thinking", "type": 1}, {"name": "images", "description": "Generated images as ImageData array", "type": 3}, {"name": "debug", "description": "Includes debugging information for when things go wrong, including stopping reason", "type": 5}], "supportedPlatforms": ["win-x86", "win-x64", "osx-x64", "osx-arm64", "linux-debian-arm64", "linux-debian-x64", "linux-rhel-arm64", "linux-rhel-x64"], "author": "0f998d5a-a8ce-4bf8-9f84-fa8c481cb40b", "defaultVariantInfo": {"title": "Agent", "shortTitle": "Agent", "description": "AI agent that processes queries with system instructions and attachments"}, "variants": [{"id": "chatInterface",