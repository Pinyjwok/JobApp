tOutputType": 1}, {"expression": "$vars.AgentSelector === 'Assembly Coordinator'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Reviewer'", "output": "input", "$lastOutputType": 1}, {"expression": "$vars.AgentSelector === 'Extractor'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'ProjectSetup'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Tone Analyst'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'History Formatter'", "output": "input", "$lastOutputType": 5}], "multipleOutputs": true, "size": {"width": 350, "height": 363}}, "type": "switch", "groupId": "{#}HibriqD"}, "{#}6ZN05f9": {"id": "{#}6ZN05f9", "canvas": {"position": {"x": -4819, "y": -6306}}, "children": [{"childId": "{#}WyF4noU", "sourcePort": "{#}6ZN05f9_innerOutput_inner-input-input-pL33Gf", "targetPort": "{#}WyF4noU_input_input"}], "state": {"description": "", "inputs": [{"name": "input-pL33Gf", "description": "Tool input data", "type": [6], "label": "input", "index": 0, "position": {"x": 757, "y": 433}}], "outputs": [], "name": "ChangeAgent", "type": "custom", "color": "#4e3eff", "canvasPosition": {"x": 510.35297873076297, "y": -125.3490057912311}, "markdownHelp": "", "settings": [], "protocolVersion": "2", "canvasZoom": 1}, "type": "widgetGroup"}, "{#}WyF4noU": {"id": "{#}WyF4noU", "canvas": {"position": {"x": 1010, "y": 381}}, "children": [{"childId": "{#}XXwend4", "sourcePort": "{#}WyF4noU_output_arguments", "targetPort": "{#}XXwend4_input_in"}], "state": {"dynamicInputs": {}, "dynamicOutputs": {}, "customState": {"name": "ChangeAgent", "description": "Use it to switch the target agent that will receive future user commands. After you trigger this tool, let the user know they are now talking with the requested agent (by name, e.g., \u201cYou\u2019re now talking to the Research agent\u201d).", "arguments": [{"name": "agent", "description": "The agent to transfer control to. MUST be one of these EXACT names (case-sensitive):\n\nMain Pipeline: 'Main Orchestrator', 'ProjectSetup', 'Extractor', 'Researcher', 'JD Enhancer', 'Analyst', 'Reviewer', 'Tone Analyst', 'Assembly Coordinator'\n\nCV Assembly: 'Style Negotiator', 'Profile Builder', 'Skills Curator', 'History Formatter', 'Credentials Formatter', 'Cover Letter Writer', 'Style Reviewer', 'Integrity Checker', 'Document Formatter'\n\nINVALID (do not use): 'Constructor', 'Interviewer', 'Research', 'Orchestrator' (use 'Main Orchestrator')", "dataType": "String", "typeDefinition": "", "typeDefinitionMode": "typescript", "required": true}], "timeout": 0}, "variantId": "tool", "service": {"name": "kemu.io.ai-agent", "version": "1.8.2", "title": "AI Agent", "description": "Define AI agents and tools for automated workflows", "processor": "js", "widgetUI": true, "settingsUI": false, "eventEmitter": true, "ignoreParentEvents": false, "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-102.48l-82.801-189.72c-6.4805-14.762-27.359-14.762-33.719 0l-82.801 189.72c-20.039 45.961-56.641 82.559-102.48 102.48l-190.08 82.922c-14.641 6.4805-14.762 27.238 0 33.719l193.44 85.441c45.719 20.281 82.199 57 102 103.08l80.039 186.12c6.3594 14.762 27.359 14.879 33.84 0l82.68-189.6c19.922-45.84 56.52-82.441 102.48-102.48l189.72-82.801c14.762-6.3594 14.762-27.238 0-33.719zm-210.84-6.9609c-3 6.7188-9.6016 10.801-16.559 10.801-2.3984 0-4.8008-0.48047-7.1992-1.4414-64.078-28.078-114.72-78.719-142.68-142.8-4.0781-9.1211 0.12109-19.801 9.2383-23.762 9.1211-3.9609 19.68 0.23828 23.762 9.3594 24.238 55.68 68.398 99.84 124.08 124.2 9.1211 3.9609 13.32 14.52 9.3594 23.641z\"/>\n <path d=\"m1113.1 322.08-109.56-47.762c-26.52-11.641-47.641-32.762-59.281-59.281l-47.762-109.56c-3.7188-8.5195-15.84-8.5195-19.55