801 7.1992 22.801 10.801 34.801 10.801 19.199 0 38.398-8.3984 50.398-26.398 19.199-27.602 13.199-66-14.398-85.199z\"/>\n <path d=\"m192 793.2c-14.398-31.199-50.398-44.398-81.602-30-31.199 14.398-44.398 50.398-30 81.602 4.8008 9.6016 8.3984 18 13.199 27.602 10.801 20.398 32.398 32.398 54 32.398 9.6016 0 19.199-2.3984 28.801-7.1992 30-15.602 40.801-52.801 25.199-82.801z\"/>\n <path d=\"m800.4 657.6-140.4-90v-223.2c0-33.602-27.602-61.199-61.199-61.199-33.602 0-61.199 27.602-61.199 61.199v256.8c0 20.398 10.801 40.801 28.801 51.602l168 106.8c9.6016 6 21.602 9.6016 32.398 9.6016 20.398 0 39.602-9.6016 51.602-28.801 17.996-27.602 9.5977-64.801-18.004-82.801z\"/>\n</svg>\n", "inputs": [{"name": "agent", "description": "Connect to the agent", "type": 5}], "outputs": [{"name": "getHistory", "description": "Invoked when the agent needs to retrieve the conversation history", "type": 5}, {"name": "updateHistory", "description": "Invoked when the agent needs to update the conversation history", "type": 5}], "color": "#eac43e"}], "publicationId": "kemu.io.ai-agent-osx-arm64-1.8.2", "sessionId": 1777873834}}, "type": "hubService", "secrets": {"OPENROUTER_API_KEY": {"name": "OPENROUTER_API_KEY", "sharedAcrossInstances": true, "hubServiceName": "kemu.io.ai-agent"}}, "groupId": "{#}oYZtu0C"}, "{#}uiZpflM": {"id": "{#}uiZpflM", "canvas": {"position": {"x": 820, "y": 642}}, "children": [{"childId": "{#}iOJxJZy", "sourcePort": "{#}uiZpflM_output_sessionHistoryOutput", "targetPort": "{#}iOJxJZy_input_input"}], "state": {"pauseExecution": false, "autoPauseOnError": true, "version": 2, "metadata": {"name": "Memory History", "description": "Keeps the history messages in memory (this is intended for dev purposes only)"}, "pages": {"main": {"code": "/**\n * Name: Memory History\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\n */\n\nconst sessions = {};\n\nconst getWidgetInputs = () => [\n  { name: 'read', type: DataType.JsonObj },\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\n];\n\nconst getWidgetOutputs = () => [\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\n];\n\nconst onParentEvent = async ({ targetPort, event }) => {\n  const inputData = event.data.value;\n\n  if (targetPort.name === 'read') {\n    const sessionId = inputData.sessionId;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'read' event missing 'sessionId' property.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\n\n  } else if (targetPort.name === 'update') {\n    const sessionId = inputData.sessionId;\n    const messagesToProcess = inputData.messages;\n\n    if (sessionId === undefined || sessionId === null) {\n      console.error(\"Error: 'update' event missing 'sessionId' property.\");\n      return;\n    }\n    if (messagesToProcess === undefined || messagesToProcess === null) {\n      console.error(\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\");\n      return;\n    }\n\n    if (!sessions[sessionId]) {\n      sessions[sessionId] = { messages: [] };\n    }\n\n    if (Array.isArray(messagesToProcess)) {\n      sessions[sessionId].messages.push(...messagesToProcess);\n    } else {\n      sessions[sessionId].messages.push(messagesToProcess);\n    }\n  }\n};", "language": "javascript", "name": "My First Script"}}}, "type": "script", "secrets": {}, "groupId": "{#}oYZtu0C"}, "{#}vZEkFKx": {"id": "{#}vZEkFKx", "canvas": {"position": {"x": 572, "y": 258}}, "children": [], "state": {"text": "# Agent Memory\n\nBasic in-memory history that allows the agent to remember chat history. This is a basic solution (make sure you instruct your agents to read and write a \u201cmemory\u201d file using their available tools to persist progress to disk).\n", "color": "#a9b8c2", "size": {"width": 917, "height": 200}, "locked": true}, "type": "note", "groupId": "{#}oYZtu0C"}, "{#}W8SWqz0": {"id": "{#}W8SWqz0", "canvas": {"position": {"x": 830, "y": 993}}, "children": [{"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_1", "targetPort": "{#}HibriqD_innerInput_inner-output-output10-VaxXpy"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_2", "targetPort": "{#}HibriqD_innerInput_inner-output-output11-EMbQUD"}, {"childId": "{#}qqtQSEB", "sourcePort": "{#}W8SWqz0_output_else", "targetPort": "{#}qqtQSEB_input_trigger"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_3", "targetPort": "{#}HibriqD_innerInput_inner-output-output12-IdLBly"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_4", "targetPort": "{#}HibriqD_innerInput_inner-output-output13-q1iOCM"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_5", "targetPort": "{#}HibriqD_innerInput_inner-output-output14-zDHC9L"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_7", "targetPort": "{#}HibriqD_innerInput_inner-output-output16-ss1i2k"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_8", "targetPort": "{#}HibriqD_innerInput_inner-output-output17-luyRFQ"}, {"childId": "{#}HibriqD", "sourcePort": "{#}W8SWqz0_output_9", "targetPort": "{#}HibriqD_innerInput_inner-output-output18-VkVcfY"}], "state": {"conditions": [{"expression": "$vars.AgentSelector === 'Style Negotiator'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Profile Builder'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Skills Curator'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Credentials Formatter'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Cover Letter Writer'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'History Formatter'", "output": "input"}, {"expression": "$vars.AgentSelector === 'Style Reviewer'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Integrity Checker'", "output": "input", "$lastOutputType": 5}, {"expression": "$vars.AgentSelector === 'Document Formatter'", "output": "input"}], "multipleOutputs": true, "size": {"width": 357, "height": 307}}, "type": "switch", "groupId": "{#}HibriqD"}, "{#}fiUdbWI": {"id": "{#}fiUdbWI", "canvas": {"position": {"x": -5944, "y": -6056}}, "children": [{"childId": "{#}bEEQme4", "targetPort": "{#}bEEQme4_input_config", "sourcePort": "{#}fiUdbWI_innerOutput_inner-input-config-NPd1HB"}], "state": {"description": "", "inputs": [{"name": "config-NPd1HB", "description": "Configuration object containing query, attachments, sessionId, and systemInstructions", "type": [6], "label": "config", "index": 0, "position": {"x": 1179, "y": 1044}}], "outputs": [], "name": "Assembly Coordinator", "type": "custom", "color": "#ab47bd", "icon": "robot", "canvasPosition": {"x": 429.7729917705193, "y": 55.74626163894891}, "markdownHelp": "", "settings": [], "protocolVersion": "2", "canvasZoom": 0.3870006488113675}, "type": "widgetGroup"}, "{#}bEEQme4": {"id": "{#}bEEQme4", "canvas": {"position": {"x": 1436, "y": 789}}, "children": [{"childId": "{#}fbEz5xj", "sourcePort": "{#}bEEQme4_output_tools", "targetPort": "{#}fbEz5xj_input_outer-input-input1"}, {"childId": "{#}JMndjs0", "sourcePort": "{#}bEEQme4_output_history", "targetPort": "{#}JMndjs0_input_outer-input-input1"}, {"childId": "{#}lgOqCv3", "sourcePort": "{#}bEEQme4_output_reasoning", "targetPort": "{#}lgOqCv3_input_setValue"}, {"childId": "{#}1Nbbghl", "sourcePort": "{#}bEEQme4_output_debug", "targetPort": "{#}1Nbbghl_input_setValue"}, {"childId": "{#}6z83lsx", "sourcePort": "{#}bEEQme4_output_text", "targetPort": "{#}6z83lsx_input_setValue"}, {"childId": "{#}6fET1C0", "sourcePort": "{#}bEEQme4_output_text", "targetPort": "{#}6fET1C0_input_event"}], "state": {"dynamicInputs": {}, "dynamicOutputs": {}, "customState": {"selectedModel": {"id": "~openai/gpt-mini-latest", "slug": "~openai/gpt-mini-latest", "name": "OpenAI GPT Mini Latest", "description": "This model always redirects to the latest model in the OpenAI GPT Mini family.", "inputModalities": ["file", "image", "text"], "outputModalities": ["text"], "supportsTools": true, "supportsReasoning": true, "promptPrice": 7.5e-07, "completionPrice": 4.5e-06, "maxTokens": 128000, "contextLength": 400000, "provider": "~openai"}, "systemInstructions": "# Assembly Coordinator v4.2 \u2014 Complete System Instructions\n\n**Version:** 4.2\n**Last Updated:** 2026-05-02\n**Role:** CV Assembly Go-Back Checkpoint + Exception Handler\n**Pipeline Position:** After Reviewer (gap interview + audit), before Style Negotiator\n**Trigger Status:** `REVIEW_COMPLETE` (auto-fired by server)\n**Input Node:** `assembly_coordinator_input`\n**Output:** `pipeline_status: SN_START` tag on proceed, or routes to MO on redo\n\n---\n\n## Role\n\nYou are the **Assembly Coordinator**.\n\n1. **Phase 0 \u2014 Load + route**: Determine invocation context from cv_assembly_state.json state.\n2. **Phase 1 \u2014 Go-Back Checkpoint**: Show fit score, backed gaps, verdict. Ask user to proceed or redo.\n3. **On proceed**: Output `pipeline_status: SN_START` tag \u2014 server dispatches Style Negotiator. Turn ENDS.\n4. **Phase 2 \u2014 Exception handling**: Handle ROUTING_INTERVENTION, INTEGRITY_FAILED, STYLE_FAILED if routed here from MO.\n5. **Phase 3 \u2014 Final assembly**: Assemble tailored_cv and write CV_TAILORED status when invoked with `__finalize__`.\n\n**You are NOT a phase router.** The server dispatches all assembly agents directly. Your only active job is the go-back checkpoint and exception handling.\n\n---\n\n## Authority\n\n### READ Access\n- `gap_analysis.json`\n- `review_audit.json`\n- `project_meta.json` (company_name, position_title)\n- `candidate_profile.json`\n- `style_guide.json`\n- `cv_assembly_state.json`\n\n### WRITE Access\n- `cv_assembly_state.json` (exception handling only)\n- `tailored_cv.json` (Phase 3 only)\n\n### NEVER Modify\n- `metadata.createdAt`\n- `gap_analysis`\n- `research_data`\n- `enhanced_jd`\n- `review_audit`\n- `candidate_profile.json`\n\n---\n\n## Tools\n\n| Tool | Usage |\n| --- | --- |\n| **ReadFile** | Load JSON and state files **using bare filenames only** |\n| **WriteFile** | Write JSON strings to files **using bare filenames only** |\n| **SwitchAgent** | Exception paths only (route to MO on unrecoverable error) |\n\n---\n\n## \u26a0\ufe0f WriteFile Rules\n\n```javascript\n\u2705 CORRECT:\nWriteFile(\"cv_assembly_state.json\", jsonString)\nWriteFile(\"tailored_cv.json\", jsonString)\n\n\u274c WRONG \u2014 named params (creates directory instead of file):\nWriteFile({ fileName: \"cv_assembly_state.json\", filePath: \"\", contents: jsonString })\n\n\u274c WRONG \u2014 leading slash:\nWriteFile(\"/cv_assembly_state.json\", jsonString)\n```\n\n---\n\n## Execution Protocol\n\n### Phase 0: Load State + Routing\n\n```javascript\nconst cvStateContent = ReadFile(\"cv_assembly_state.json\")\nconst cvState = JSON.parse(cvStateContent)\nconst gapAnalysis = JSON.parse(ReadFile(\"gap_analysis.json\"))\nconst reviewAudit = JSON.parse(ReadFile(\"review_audit.json\"))\nconst projectMeta = JSON.parse(ReadFile(\"project_meta.json\"))\n\n// Route based on state\nconst cvStatus = cvState.metadata.status\nconst currentPhase = cvState.current_phase\n\nif (currentPhase > 8 || (cvStatus === 'ACTIVE' && cvState.phases.every(p => p.status === 'COMPLETE'))) {\n  GOTO Phase 3  // Final assembly\n}\n\nif (cvStatus === 'ROUTING_INTERVENTION' || cvStatus === 'INTEGRITY_FAILED' || cvStatus === 'STYLE_FAILED') {\n  GOTO Phase 2  // Exception handling\n}\n\n// Default: go-back checkpoint (fresh invocation after REVIEW_COMPLETE)\nGOTO Phase 1\n```\n\n---\n\n### Phase 1: Go-Back Checkpoint\n\n**Purpose:** Before CV building begins, show the analysis summary and ask the user to confirm they want to proceed.\n\n```javascript\nconst fitScore = gapAnalysis?.overall_fit_score ?? '?'\nconst fitScoreRevised = gapAnalysis?.fit_score_revised_by_reviewer ?? false\nconst revisionNote = gapAnalysis?.fit_score_revision_note ?? ''\nconst backedStrengths = gapAnalysis?.candidate_backed_strengths ?? []\nconst overallVerdict = reviewAudit?.overall_verdict ?? 'UNKNOWN'\nconst totalGaps = (gapAnalysis?.gaps ?? []).filter(g => g.severity === 'High' || g.severity === 'Medium').length\nconst approvedItems = reviewAudit?.summary?.approved_items ?? '?'\nconst issues = reviewAudit?.summary?.unresolved_issues ?? 0\nconst positionTitle = projectMeta?.position_title ?? 'the role'\nconst companyName = projectMeta?.company_name ?? 'the company'\n```\n\nDisplay:\n\n```markdown\n# Analysis Complete \u2014 Ready to Build CV\n\n**Role:** {positionTitle} at {companyName}\n**Fit Score:** {fitScore}/10{IF fitScoreRevised: \" _(revised from initial score \u2014 {revisionNote})_\"}\n\n## Gap Analysis Summary\n\n**Quality Audit:** {overallVerdict}\n- Verified claims: {approvedItems}\n- Unresolved issues: {issues}\n{IF backedStrengths.length > 0:\n\"- **Gaps you provided evidence for:** {backedStrengths.length} \u2014 these will be included as CV material\"\n}\n{IF totalGaps > 0:\n\"- **Remaining gaps:** {totalGaps} (medium\u2013high severity) \u2014 assembly agents will handle these with available evidence\"\n}\n\n---\n\n```\n\nTurn ENDS. Server injects action buttons (Proceed \u2014 build CV / Go back & review) \u2014 do NOT await typed user input.\n\n**If invoked with message \"proceed\"** (server-injected when user clicks Proceed button):\n\nOutput:\n```\n# \u2713 Ready to build CV \u2014 starting style negotiation.\n\npipeline_status: SN_START\n```\n\n**TURN ENDS. DO NOT call SwitchAgent or set_status \u2014 server parses the tag and dispatches Style Negotiator.**\n\n**If invoked with message \"redo\"** (server routes this to Main Orchestrator \u2014 AC will not see this message):\n```\n// Handled by server \u2014 ChangeAgent not needed here\n```\n\n---\n\n### Phase 2: Exception Handling\n\n**Purpose:** Handle exceptions when cv_assembly_state.json status is non-ACTIVE.\n\n#### Exception 1: ROUTING_INTERVENTION\n\n```javascript\nconst content = ReadFile(\"cv_assembly_state.json\")\nconst cvState = JSON.parse(content)\nconst userRequest = cvState.user_request\nconst currentPhase = cvState.current_phase\nconst requestedSection = userRequest.section\n\nDisplay: `\n**User Request Detected**\n\nYou requested a change to **${requestedSection}** while at phase ${currentPhase}.\n\nThis will regenerate: ${getAffectedSections(requestedSection)}\n\n- Type **proceed** to regenerate sections\n- Type **cancel** to continue without changes\n`\n\nWAIT for user response\nEND TURN\n\n// When user responds:\nIF user says \"proceed\":\n  const affectedPhases = getAffectedPhases(requestedSection)\n  affectedPhases.forEach(phaseNum => {\n    cvState.phases[phaseNum - 1].status = \"PENDING\"\n    cvState.phases[phaseNum - 1].data = null\n  })\n  cvState.current_phase = Math.min(...affectedPhases)\n  cvState.metadata.status = \"ACTIVE\"\n  cvState.metadata.last_updated = getCurrentISOTimestamp()\n\n  WriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n  const verifyRI = JSON.parse(ReadFile(\"cv_assembly_state.json\"))\n  if (verifyRI.metadata.status !== \"ACTIVE\") {\n    Display: \"WriteFile verify failed. Type 'retry' or 'abort'.\"\n    WAIT for user response\n    IF user says \"retry\": retry write\n    ELSE: ChangeAgent(agent: \"Main Orchestrator\"); END TURN\n  }\n\n  Display: `Resetting to phase ${cvState.current_phase}\u2026\\n\\nSend any message to continue.\\n\\npipeline_status: CV_BUILDING`\n  END TURN\n\nELSE IF user says \"cancel\":\n  cvState.metadata.status = \"ACTIVE\"\n  cvState.user_request = null\n  cvState.metadata.last_updated = getCurrentISOTimestamp()\n  WriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n  Display: `Continuing from phase ${cvState.current_phase}.\\n\\nSend any message to continue.\\n\\npipeline_status: CV_BUILDING`\n  END TURN\n```\n\n#### Exception 2: INTEGRITY_FAILED\n\n```javascript\nconst content = ReadFile(\"cv_assembly_state.json\")\nconst cvState = JSON.parse(content)\nconst integrityIssues = cvState.phases[7].data.unsupported_claims_detail\n  || cvState.phases[7].data.ic_corrections\n  || []\n\nDisplay: `\n**Integrity Check Failed**\n\n${integrityIssues.length} unsupported claims found:\n${integrityIssues.map(c => `\u2022 [${c.section}] ${c.claim} \u2014 ${c.evidence_status}`).join('\\n')}\n\n- Type **fix** to regenerate affected sections\n- Type **accept anyway** to proceed with warnings\n`\n\nWAIT for user response\nEND TURN\n\nIF user says \"fix\":\n  const affectedPhases = identifyAffectedPhases(integrityIssues)\n  affectedPhases.forEach(phaseNum => {\n    cvState.phases[phaseNum - 1].status = \"PENDING\"\n    cvState.phases[phaseNum - 1].data = null\n  })\n  cvState.current_phase = Math.min(...affectedPhases)\n  cvState.metadata.status = \"ACTIVE\"\n  cvState.metadata.last_updated = getCurrentISOTimestamp()\n  WriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n  Display: `Regenerating affected sections\u2026\\n\\nSend any message to continue.\\n\\npipeline_status: CV_BUILDING`\n  END TURN\n\nIF user says \"accept anyway\":\n  cvState.phases[7].status = \"COMPLETE\"\n  cvState.phases[7].completed_at = getCurrentISOTimestamp()\n  cvState.current_phase = 9\n  cvState.metadata.status = \"ACTIVE\"\n  cvState.metadata.last_updated = getCurrentISOTimestamp()\n  WriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n  Display: `Proceeding despite integrity warnings.\\n\\nSend any message to continue.\\n\\npipeline_status: CV_BUILDING`\n  END TURN\n```\n\n#### Exception 3: STYLE_FAILED\n\n```javascript\nconst content = ReadFile(\"cv_assembly_state.json\")\nconst cvState = JSON.parse(content)\nconst styleIssues = cvState.phases[6].data.issues_found || []\n\nDisplay: `\n**Style Review Failed**\n\n${styleIssues.length} style violations found:\n${styleIssues.map(i => `\u2022 ${i}`).join('\\n')}\n\n- Type **fix** to regenerate affected sections\n- Type **accept anyway** to proceed with violations\n`\n\nWAIT for user response\nEND TURN\n\nIF user says \"fix\":\n  const affectedPhases = identifyStyleAffectedPhases(styleIssues)\n  affectedPhases.forEach(phaseNum => {\n    cvState.phases[phaseNum - 1].status = \"PENDING\"\n    cvState.phases[phaseNum - 1].data = null\n  })\n  cvState.current_phase = Math.min(...affectedPhases)\n  cvState.metadata.status = \"ACTIVE\"\n  cvState.metadata.last_updated = getCurrentISOTimestamp()\n  WriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n  Display: `Regenerating to fix style violations.\\n\\nSend any message to continue.\\n\\npipeline_status: CV_BUILDING`\n  END TURN\n\nIF user says \"accept anyway\":\n  cvState.phases[6].status = \"COMPLETE\"\n  cvState.phases[6].completed_at = getCurrentISOTimestamp()\n  cvState.current_phase = 8\n  cvState.metadata.status = \"ACTIVE\"\n  cvState.metadata.last_updated = getCurrentISOTimestamp()\n  WriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n  Display: `Proceeding despite style violations.\\n\\nSend any message to continue.\\n\\npipeline_status: CV_BUILDING`\n  END TURN\n```\n\n---\n\n### Phase 3: Final Assembly\n\n**Purpose:** Assemble the final tailored_cv object and signal CV_TAILORED.\n\n**Triggered by:** Server `done_IC` handler invoking AC with `__finalize__`, OR current_phase > 8.\n\n```javascript\nconst cvStateContent = ReadFile(\"cv_assembly_state.json\")\nconst cvState = JSON.parse(cvStateContent)\nconst gapAnalysis2 = JSON.parse(ReadFile(\"gap_analysis.json\"))\nconst reviewAudit2 = JSON.parse(ReadFile(\"review_audit.json\"))\nconst projectMeta2 = JSON.parse(ReadFile(\"project_meta.json\"))\n\nconst styleData       = cvState.phases[0].data\nconst profileData     = cvState.phases[1].data\nconst skillsData      = cvState.phases[2].data\nconst historyData     = cvState.phases[3].data\nconst credentialsData = cvState.phases[4].data\nconst coverLetterData = cvState.phases[5].data\nconst styleReviewData = cvState.phases[6].data\nconst integrityData   = cvState.phases[7].data\n\nconst finalCV = {\n  metadata: {\n    created_at: getCurrentISOTimestamp(),\n    company: projectMeta2.company_name,\n    position: projectMeta2.position_title,\n    version: '1.0',\n  },\n  style_preferences: styleData,\n  contact_details: profileData?.contact_details,\n  professional_summary: profileData?.professional_summary,\n  skills: skillsData,\n  work_history: historyData,\n  education_and_credentials: credentialsData,\n  cover_letter: coverLetterData,\n  quality_checks: {\n    style_verified: styleReviewData?.style_compliance === 'PASS',\n    integrity_verified: integrityData?.integrity_status === 'PASSED',\n    style_issues: styleReviewData?.issues_found || [],\n    integrity_issues: integrityData?.unsupported_claims_detail || [],\n  },\n  change_log: cvState.change_log,\n}\n\nWriteFile(\"tailored_cv.json\", JSON.stringify(finalCV, null, 2))\nconst tcVerify = JSON.parse(ReadFile(\"tailored_cv.json\"))\nif (!tcVerify?.metadata) {\n  WriteFile(\"tailored_cv.json\", JSON.stringify(finalCV, null, 2))\n  const tcVerify2 = JSON.parse(ReadFile(\"tailored_cv.json\"))\n  if (!tcVerify2?.metadata) {\n    Display: \"WriteFile failed for tailored_cv.json. Type 'retry' or 'abort'.\"\n    WAIT; IF retry: retry write; ELSE: ChangeAgent(\"Main Orchestrator\"); END TURN\n  }\n}\n\ncvState.final_cv = finalCV\ncvState.metadata.last_updated = getCurrentISOTimestamp()\ncvState.metadata.status = 'COMPLETE'\nWriteFile(\"cv_assembly_state.json\", JSON.stringify(cvState, null, 2))\n\n// \u26a0\ufe0f VERIFY BEFORE DISPLAY \u2014 both files must be confirmed written\n// tailored_cv.json: metadata present \u2713\n// cv_assembly_state.json: final_cv present \u2713\n\n// Completion display\nconst fitScore       = gapAnalysis2?.overall_fit_score ?? 'N/A'\nconst strengthsCount = gapAnalysis2?.strengths?.length || 0\nconst gapsCount      = gapAnalysis2?.gaps?.length || 0\nconst icCorrections  = cvState.phases[7].data?.ic_corrections?.length || 0\nconst reviewVerdict  = reviewAudit2?.overall_verdict || 'UNKNOWN'\nconst skillsCount    = (skillsData?.technical_skills?.length || 0) + (skillsData?.soft_skills?.length || 0)\n\nDisplay: `\n# \u2713 Application Preparation Complete!\n\n**Company:** ${projectMeta2.company_name}\n**Position:** ${projectMeta2.position_title}\n**Overall Fit Score:** ${fitScore}/10\n\n## Generated Materials\n\n\u2713 Company research (7 key insights)\n\u2713 Enhanced job description with context\n\u2713 Gap analysis (${strengthsCount} strengths, ${gapsCount} gaps)\n${reviewVerdict === 'APPROVED' ? '\u2713 Quality review: Approved' : `- Quality review: ${reviewVerdict} (accepted by user override)`}\n\u2713 Writing style analysed and optimised\n\u2713 Optimised CV${icCorrections > 0 ? ` (${icCorrections} integrity corrections applied)` : ''}\n  - Professional Summary\n  - ${skillsCount} skills organised\n  - Cover Letter\n\n## Quality Checks\n\n**Style Consistency:** ${styleReviewData?.style_compliance === 'PASS' ? '\u2713 Passed' : '\u26a0 Issues found'}\n**Integrity Verification:** ${integrityData?.integrity_status === 'PASSED' ? '\u2713 Passed' : '\u26a0 Issues found'}\n\nAll data saved in tailored_cv.json\n\nCommands: 'review analysis' \u00b7 'review cv' \u00b7 'review changes' \u00b7 'review audit' \u00b7 'start over'\n`\n\n// Workflow complete \u2014 no SwitchAgent, turn ENDS\n```\n\n---\n\n## State Invalidation Matrix\n\n```javascript\nconst INVALIDATION_MATRIX = {\n  'style':        { affects: [1,2,3,4,5,6,7] },\n  'contact':      { affects: [2] },\n  'profile':      { affects: [2,7,8] },\n  'skills':       { affects: [3,7,8] },\n  'history':      { affects: [4,7,8] },\n  'credentials':  { affects: [5,7,8] },\n  'cover_letter': { affects: [6,7,8] },\n}\n\nfunction getAffectedPhases(section) {\n  return INVALIDATION_MATRIX[section]?.affects || []\n}\n\nfunction getAffectedSections(section) {\n  const phases = getAffectedPhases(section)\n  const phaseNames = [\n    'Style Negotiation', 'Profile Building', 'Skills Curation', 'History Formatting',\n    'Credentials Formatting', 'Cover Letter Writing', 'Style Review', 'Integrity Check',\n  ]\n  return phases.map(p => `Phase ${p}: ${phaseNames[p-1]}`).join('\\n')\n}\n```\n\n---\n\n## Error Handling\n\n| Error | Action |\n| --- | --- |\n| cv_assembly_state.json missing | Display error, ChangeAgent(\"Main Orchestrator\") |\n| gap_analysis.json or project_meta.json missing | Display error, ChangeAgent(\"Main Orchestrator\") |\n| Unknown exception status | Display error, ChangeAgent(\"Main Orchestrator\") |\n| WriteFile fails | Retry once; after 2nd failure, prompt user for 'retry'/'abort' |\n| Filename has slash | CRITICAL ERROR |\n\n---\n\n## Critical Rules\n\n**`getCurrentISOTimestamp()` implementation** \u2014 Extract the current date from the system context (\"Today's date is YYYY-MM-DD\") and return it as ISO 8601: `YYYY-MM-DDT00:00:00Z`. Never hardcode a specific date string.\n\n1. **Route on cv_assembly_state status** \u2014 ROUTING_INTERVENTION/INTEGRITY_FAILED/STYLE_FAILED \u2192 Phase 2 exception handling\n2. **Phase 0 load determines context** \u2014 don't assume; read state first\n3. **`pipeline_status: SN_START` tag on proceed** \u2014 server dispatches Style Negotiator; do not call SwitchAgent or set_status\n4. **SwitchAgent only for MO routing on redo/error** \u2014 not for normal flow\n5. **Use bare filenames** \u2014 no leading slashes\n6. **Always stringify JSON** \u2014 before WriteFile\n7. **WriteFile verify** \u2014 read back after write; retry once before surfacing error\n8. **User confirmation required** \u2014 for all exception-path regenerations\n9. **Bare filenames only** \u2014 `\"tailored_cv.json\"` not `\"/tailored_cv.json\"`\n10. **Phase 3 verify before display** \u2014 both files confirmed written before showing completion\n\n---\n", "query": "", "jsonResponse": false, "jsonFormat": "", "jsonSchemaMode": "typescript", "fileParser": "native", "imageAspectRatio": "1:1", "maxIterations": 25, "reasoningEffort": "medium", "allowFallbacks": true, "temperature": 0}, "service": {"name": "kemu.io.ai-agent", "version": "1.8.2", "title": "AI Agent", "description": "Define AI agents and tools for automated workflows", "processor": "js", "widgetUI": true, "settingsUI": false, "eventEmitter": true, "ignoreParentEvents": false, "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m875.64 681.36-189.72-82.801c-45.961-19.922-82.559-56.52-102.48-102.48l-82.801-189.72c-6.4805-14.762-27.359-14.762-33.719 0l-82.801 189.72c-20.039 45.961-56.641 82.559-102.48 102.48l-190.08 82.922c-14.641 6.4805-14.762 27.238 0 33.719l193.44 85.441c45.719 20.281 82.199 57 102 103.08l80.039 186.12c6.3594 14.762 27.359 14.879 33.84 0l82.68-189.6c19.922-45.84 56.52-82.441 102.48-102.48l189.72-82.801c14.762-6.3594 14.762-27.238 0-33.719zm-210.84-6.9609c-3 6.7188-9.6016 10.801-16.559 10.801-2.3984 0-4.8008-0.48047-7.1992-1.4414-64.078-28.078-114.72-78.719-142.68-142.8-4.0781-9.1211 0.12109-19.801 9.2383-23.762 9.1211-3.9609 19.68 0.23828 23.762 9.3594 24.238 55.68 68.398 99.84 124.08 124.2 9.1211 3.9609 13.32 14.52 9.3594 23.641z\"/>\n <path d=\"m1113.1 322.08-109.56-47.762c-26.52-11.641-47.641-32.762-59.281-59.281l-47.762-109.56c-3.7188-8.5195-15.84-8.5195-19.559 0l-47.762 109.56c-11.641 26.52-32.762 47.641-59.281 59.281l-109.68 47.879c-8.5195 3.7188-8.5195 15.719-0.12109 19.441l111.72 49.32c26.398 11.762 47.52 33 58.922 59.52l46.32 107.64c3.6016 8.5195 15.719 8.5195 19.441 0l47.762-109.44c11.641-26.52 32.762-47.641 59.281-59.281l109.56-47.762c8.5195-3.7188 8.5195-15.84 0-19.559zm-149.28 15.84c-3.4805 5.6406-9.3594 8.6406-15.48 8.6406-3.1211 0-6.3594-0.83984-9.2383-2.5195-24.84-15.121-45.359-34.922-61.199-59.16-5.3984-8.3984-3-19.441 5.2812-24.961 8.2812-5.3984 19.441-3.1211 24.84 5.2812 12.961 19.68 29.641 35.762 49.68 48 8.5195 5.1602 11.281 16.199 6.1211 24.719z\"/>\n</svg>\n", "color": "#42a5f5", "mdHelp": "/docs/help/service.md", "customWidgets": [{"name": "Memory History", "color": "#eac43e", "description": "Provides a simple in-memory history manager for debugging purposes.", "contents": "KMU-CB-v1{\"{#}mBE0gxc\":{\"id\":\"{#}mBE0gxc\",\"canvas\":{\"position\":{\"x\":2006,\"y\":726}},\"children\":[{\"childId\":\"{#}4M2WbT3\",\"sourcePort\":\"{#}mBE0gxc_innerOutput_inner-input-input1\",\"targetPort\":\"{#}4M2WbT3_input_agent\"}],\"state\":{\"description\":\"Provides a simple in-memory history manager for debugging purposes.\",\"inputs\":[{\"index\":0,\"label\":\"agent\",\"name\":\"input1\",\"type\":[5],\"position\":{\"x\":519,\"y\":291}}],\"outputs\":[],\"name\":\"Memory History\",\"type\":\"custom\",\"color\":\"#eac43e\",\"icon\":\"database\",\"canvasPosition\":{\"x\":0,\"y\":0},\"markdownHelp\":\"\",\"settings\":[],\"protocolVersion\":\"2\"},\"type\":\"widgetGroup\"},\"{#}4M2WbT3\":{\"id\":\"{#}4M2WbT3\",\"canvas\":{\"position\":{\"x\":659,\"y\":341}},\"children\":[{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_getHistory\",\"targetPort\":\"{#}jCnteeA_input_read\"},{\"childId\":\"{#}jCnteeA\",\"sourcePort\":\"{#}4M2WbT3_output_updateHistory\",\"targetPort\":\"{#}jCnteeA_input_update\"}],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{\"includeAttachments\":false,\"timeout\":60},\"variantId\":\"history\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"groupId\":\"{#}mBE0gxc\"},\"{#}a5vxU9Y\":{\"id\":\"{#}a5vxU9Y\",\"canvas\":{\"position\":{\"x\":1235,\"y\":488}},\"children\":[],\"state\":{\"dynamicInputs\":{},\"dynamicOutputs\":{},\"customState\":{},\"variantId\":\"submit\",\"service\":{\"name\":\"kemu.io.ai-agent\",\"version\":\"0.1.0\",\"title\":\"AI Agent\",\"description\":\"Define AI agents and tools for automated workflows\",\"processor\":\"js\",\"widgetUI\":true,\"settingsUI\":false,\"eventEmitter\":false,\"ignoreParentEvents\":false,\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- AI Agent icon - brain/robot head -->\\n  <path d=\\\"M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z\\\" fill=\\\"currentColor\\\"/>\\n  <circle cx=\\\"9.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <circle cx=\\\"14.5\\\" cy=\\\"9\\\" r=\\\"1.5\\\" fill=\\\"white\\\"/>\\n  <path d=\\\"M12 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\\\" fill=\\\"white\\\"/>\\n  <rect x=\\\"10\\\" y=\\\"19\\\" width=\\\"4\\\" height=\\\"3\\\" rx=\\\"1\\\" fill=\\\"currentColor\\\"/>\\n</svg>\",\"color\":\"#42a5f5\",\"inputs\":[{\"name\":\"query\",\"description\":\"Query string for the agent\",\"type\":1},{\"name\":\"attachments\",\"description\":\"Attachments for the agent (String, BinaryFile, ImageData, or Array of these types)\",\"type\":[1,12,7,3]},{\"name\":\"clear\",\"description\":\"Clear input signal\",\"type\":6},{\"name\":\"abort\",\"description\":\"Abort current query signal\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"secrets\":{\"OPENROUTER_API_KEY\":{\"name\":\"OPENROUTER_API_KEY\",\"hubServiceName\":\"kemu.io.ai-agent\"}},\"groupId\":\"{#}mBE0gxc\"},\"{#}jCnteeA\":{\"id\":\"{#}jCnteeA\",\"canvas\":{\"position\":{\"x\":948,\"y\":397}},\"children\":[{\"childId\":\"{#}a5vxU9Y\",\"sourcePort\":\"{#}jCnteeA_output_sessionHistoryOutput\",\"targetPort\":\"{#}a5vxU9Y_input_input\"}],\"state\":{\"pauseExecution\":false,\"autoPauseOnError\":true,\"version\":2,\"metadata\":{\"name\":\"Memory History\",\"description\":\"Keeps the history messages in memory (this is intended for dev purposes only)\"},\"pages\":{\"main\":{\"code\":\"/**\\n * Name: Memory History\\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\\n */\\n\\nconst sessions = {};\\n\\nconst getWidgetInputs = () => [\\n  { name: 'read', type: DataType.JsonObj },\\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\\n];\\n\\nconst getWidgetOutputs = () => [\\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\\n];\\n\\nconst onParentEvent = async ({ targetPort, event }) => {\\n  const inputData = event.data.value;\\n\\n  if (targetPort.name === 'read') {\\n    const sessionId = inputData.sessionId;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'read' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\\n\\n  } else if (targetPort.name === 'update') {\\n    const sessionId = inputData.sessionId;\\n    const messagesToProcess = inputData.messages;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'update' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n    if (messagesToProcess === undefined || messagesToProcess === null) {\\n      console.error(\\\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    if (Array.isArray(messagesToProcess)) {\\n      sessions[sessionId].messages.push(...messagesToProcess);\\n    } else {\\n      sessions[sessionId].messages.push(messagesToProcess);\\n    }\\n  }\\n};\",\"language\":\"javascript\",\"name\":\"My First Script\"}}},\"type\":\"script\",\"secrets\":{},\"groupId\":\"{#}mBE0gxc\"}}", "rootGroupId": "{#}mBE0gxc", "icon": "database", "protocolVersion": "2"}], "inputs": [{"name": "config", "description": "Configuration object containing query, attachments, sessionId, and systemInstructions. Can also be a string to be used as query or a boolean to trigger processing.", "type": [5, 4, 1, 6]}, {"name": "abort", "description": "Abort current query signal", "type": 6}], "outputs": [{"name": "tools", "type": 5}, {"name": "history", "type": 5}, {"name": "json", "type": 5}, {"name": "text", "type": 1}, {"name": "stream", "type": 1}, {"name": "reasoning", "description": "Reasoning output from models that support extended thinking", "type": 1}, {"name": "images", "description": "Generated images as ImageData array", "type": 3}, {"name": "debug", "description": "Includes debugging information for when things go wrong, including stopping reason", "type": 5}], "supportedPlatforms": ["win-x86", "win-x64", "osx-x64", "osx-arm64", "linux-debian-arm64", "linux-debian-x64", "linux-rhel-arm64", "linux-rhel-x64"], "author": "0f998d5a-a8ce-4bf8-9f84-fa8c481cb40b", "defaultVariantInfo": {"title": "Agent", "shortTitle": "Agent", "description": "AI agent that processes queries with system instructions and attachments"}, "variants": [{"id": "chatInterface", "name": "Chat Interface", "description": "Chat window UI that can invoke an Agent and display live outputs", "svgIcon": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m1034.4 486-298.78-46.781v244.78c0 26.391-10.781 50.391-31.219 67.219-15.609 14.391-36 21.609-57.609 21.609-4.7812 0-9.6094 0-14.391-1.2188l-134.39-20.391v80.391c0 15.609 7.2188 30 18 39.609 12 10.781 27.609 14.391 43.219 12l309.61-48h8.4375c1.2188 0 1.2188 1.2188 2.3906 1.2188 1.2188 1.2188 2.3906 1.2188 3.6094 2.3906l111.61 96-4.7812-103.22v-4.8281c0-1.2188 1.2188-3.6094 2.3906-4.7812 0-1.2188 0-1.2188 1.2188-1.2188 1.2188-1.2188 1.2188-1.2188 2.3906-2.3906 1.2188 0 1.2188-1.2188 2.3906-1.2188 1.2188 0 1.2188-1.2188 3.6094-1.2188 1.2188 0 1.2188-1.2188 2.3906-1.2188l28.781-4.7812c26.391-3.6094 45.609-26.391 45.609-52.781l-0.09375-217.18c1.2188-26.391-18-49.219-44.391-54z\"/>\n <path d=\"m681.61 724.78c12-9.6094 18-25.219 18-39.609v-367.18c0-15.609-7.2188-30-18-40.781-12-9.6094-27.609-14.391-43.219-12l-474 74.391c-26.391 4.7812-45.609 26.391-45.609 52.781v217.22c0 26.391 19.219 49.219 45.609 52.781l28.781 4.7812c1.2188 0 1.2188 1.2188 2.3906 1.2188 1.2188 0 2.3906 1.2188 3.6094 1.2188 1.2188 1.2188 2.3906 1.2188 2.3906 2.3906 1.2188 0 2.4375 0 2.4375 1.2188 1.2188 1.2188 1.2188 2.3906 1.2188 3.6094s1.2188 1.2188 1.2188 2.3906v6l-2.4375 103.17 111.61-96h1.2188c1.2188-1.2188 2.3906-1.2188 3.6094-1.2188 1.2188-1.2188 1.2