801 39.117l-84.16 135.09c11.793 117.27-81.285 221.63-200.24 221.63-111.13 0-201.26-90.129-201.26-201.28 0-117.13-16.371-179.8-55.09-299.45-22.52-69.621 48.203-91.402 70.398-22.777l46.844 144.77-9.2852-233c0-73.176 74-72.141 74 0l11.227 190.89 29.977-13.594 0.65234-241.1c0-73.176 73.984-72.141 73.984 0l3.2305 225.09 28.051-4.5195z\"></path>\n</svg>\n","canvasPosition":{"x":0,"y":38.000000000000114},"markdownHelp":"","settings":[],"protocolVersion":"2","canvasZoom":1},"type":"widgetGroup","groupId":"{#}gt2l79i"},"{#}gN5gRmV":{"id":"{#}gN5gRmV","canvas":{"position":{"x":515,"y":608}},"children":[{"childId":"{#}ZhDNUgz","sourcePort":"{#}gN5gRmV_output_value","targetPort":"{#}ZhDNUgz_innerInput_inner-output-output1"}],"state":{"name":"Settings.Abort_All_Processing","reactive":true,"lastConfiguration":{"controlType":"anything","controlSettings":{"value":null},"helpText":"Linked to the 'abort' ports of all agents","group":"Settings"}},"type":"globalVariable","groupId":"{#}ZhDNUgz"},"{#}rY7WEjS":{"id":"{#}rY7WEjS","canvas":{"position":{"x":317,"y":227}},"children":[],"state":{"text":"# Abort Processing\n\nReacts to 'abort' events produced by the chat interface. Copy this widget for every agent you create and link it to the 'abort' input port.\n","color":"#a9b8c2","size":{"width":631,"height":200},"locked":true},"type":"note","groupId":"{#}ZhDNUgz"},"{#}TKtYXu5":{"id":"{#}TKtYXu5","canvas":{"position":{"x":-6112,"y":-7146}},"children":[],"state":{"text":"MO:\\\nPhase 1 — \"YOU ARE ALREADY MO\" block: Explicit note that the model is already the Main Orchestrator, does not need to\\\ncall SwitchAgent/ChangeAgent to transition into itself, and must act immediately based on status. This targets BUG-116\n(ChangeAgent self-switch in reasoning).\n\n1. Phase 4 — zero-preamble enforcement: Added ⛔ Your output MUST begin with ⚠ Quality Review Found Issues —\n   first-character enforcement is the strongest signal the model can act on. Also targets BUG-115 (narration before menu).\n2. Banned phrases expanded: Added the exact reasoning-level phrases seen in the screenshot — \"I'm now shifting gears\",\n   \"Activating Orchestrator Task\", \"Transitioning Orchestration Control\", \"putting on the Main Orchestrator hat\". These are\\\n   the cognitive self-narration patterns that produce the visible output violation.\n\n","color":"#eac43e","size":{"width":719,"height":271},"locked":false},"type":"note"},"{#}YrQTccT":{"id":"{#}YrQTccT","canvas":{"position":{"x":-4831,"y":-6212}},"children":[{"childId":"{#}YPHqB0K","sourcePort":"{#}YrQTccT_innerOutput_inner-input-input1-CDDpbo","targetPort":"{#}YPHqB0K_input_input"}],"state":{"description":"","inputs":[{"name":"input1-CDDpbo","label":"tools","type":[6],"index":0,"position":{"x":1920,"y":898}}],"outputs":[],"name":"ResearchCompany","type":"custom","color":"#42a5f5","icon":"search","canvasPosition":{"x":1352.935329587277,"y":251.9173479400422},"markdownHelp":"","settings":[],"protocolVersion":"2","canvasZoom":0.6239125267098532},"type":"widgetGroup"},"{#}YPHqB0K":{"id":"{#}YPHqB0K","canvas":{"position":{"x":2170.3304331452355,"y":900.0785941463063}},"children":[{"childId":"{#}dV0nJ7o","sourcePort":"{#}YPHqB0K_output_arguments","targetPort":"{#}dV0nJ7o_input_event"}],"state":{"dynamicInputs":{},"dynamicOutputs":{},"customState":{"name":"ResearchCompany","description":"Researches company specified in PD","arguments":[{"name":"companyName","description":"Company to research","dataType":"String","typeDefinition":"","typeDefinitionMode":"typescript","required":true},{"name":"positionTitle","description":"Position to target CV for\n","dataType":"String","typeDefinition":"","typeDefinitionMode":"typescript","required":true},{"name":"sector","description":"Targeted companies sector for research\n","dataType":"String","typeDefinition":"","typeDefinitionMode":"typescript","required":true}],"timeout":10},"variantId":"tool","service":{"name":"kemu.io.ai-agent","version":"1.8.2","title":"AI Agent","description":"Defi