al\",\"type\":6},{\"name\":\"send\",\"description\":\"Send input signal\",\"type\":6}],\"outputs\":[{\"name\":\"tools\",\"type\":5},{\"name\":\"history\",\"type\":5},{\"name\":\"json\",\"type\":5},{\"name\":\"text\",\"type\":1},{\"name\":\"stream\",\"type\":1},{\"name\":\"images\",\"description\":\"Generated images as ImageData array\",\"type\":3}],\"supportedPlatforms\":[\"win-x86\",\"win-x64\",\"osx-x64\",\"osx-arm64\",\"linux-debian-arm64\",\"linux-debian-x64\",\"linux-rhel-arm64\",\"linux-rhel-x64\"],\"author\":\"db618814-4e68-40aa-8158-64a595fea23b\",\"defaultVariantInfo\":{\"title\":\"Agent\",\"shortTitle\":\"Agent\",\"description\":\"AI agent that processes queries with system instructions and attachments\"},\"variants\":[{\"id\":\"tool\",\"name\":\"Tool\",\"description\":\"Define tools with arguments and results for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Tool icon - wrench/settings -->\\n  <path d=\\\"M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Tool input data\",\"type\":5}],\"outputs\":[{\"name\":\"arguments\",\"description\":\"Tool arguments\",\"type\":5}],\"color\":\"#42a5f5\"},{\"id\":\"submit\",\"name\":\"Submit\",\"description\":\"Submit data without any processing\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\">\\n  <!-- Submit icon - send/arrow -->\\n  <path d=\\\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\\\" fill=\\\"currentColor\\\"/>\\n</svg>\\n\",\"inputs\":[{\"name\":\"input\",\"description\":\"Data to submit\",\"type\":6}],\"color\":\"#68bb6c\"},{\"id\":\"history\",\"name\":\"History\",\"description\":\"Manage conversation history and session storage for AI agents\",\"svgIcon\":\"<svg fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 16 16\\\">\\n  <path\\n    d=\\\"M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M8 3.5a.5.5 0 0 1 .5.5v4l2.5 1.5a.5.5 0 0 1-.5.866L7.5 8.866A.5.5 0 0 1 7.5 8V4a.5.5 0 0 1 .5-.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n  <path\\n    d=\\\"M2.5 8a5.5 5.5 0 0 1 5.5-5.5V1A7 7 0 0 0 1 8h1.5z\\\"\\n    fill=\\\"white\\\"\\n  />\\n</svg>\\n\",\"inputs\":[{\"name\":\"agent\",\"description\":\"Connect to the agent\",\"type\":5}],\"outputs\":[{\"name\":\"getHistory\",\"description\":\"Invoked when the agent needs to retrieve the conversation history\",\"type\":5},{\"name\":\"updateHistory\",\"description\":\"Invoked when the agent needs to update the conversation history\",\"type\":5}],\"color\":\"#9c27b0\"}],\"internal\":false,\"devMode\":true,\"sessionId\":1760512532}},\"type\":\"hubService\",\"secrets\":{\"OPENROUTER_API_KEY\":{\"name\":\"OPENROUTER_API_KEY\",\"hubServiceName\":\"kemu.io.ai-agent\"}},\"groupId\":\"{#}mBE0gxc\"},\"{#}jCnteeA\":{\"id\":\"{#}jCnteeA\",\"canvas\":{\"position\":{\"x\":948,\"y\":397}},\"children\":[{\"childId\":\"{#}a5vxU9Y\",\"sourcePort\":\"{#}jCnteeA_output_sessionHistoryOutput\",\"targetPort\":\"{#}a5vxU9Y_input_input\"}],\"state\":{\"pauseExecution\":false,\"autoPauseOnError\":true,\"version\":2,\"metadata\":{\"name\":\"Memory History\",\"description\":\"Keeps the history messages in memory (this is intended for dev purposes only)\"},\"pages\":{\"main\":{\"code\":\"/**\\n * Name: Memory History\\n * Description: Keeps the history messages in memory (this is intended for dev purposes only)\\n */\\n\\nconst sessions = {};\\n\\nconst getWidgetInputs = () => [\\n  { name: 'read', type: DataType.JsonObj },\\n  { name: 'update', type: [DataType.JsonObj, DataType.Array] }\\n];\\n\\nconst getWidgetOutputs = () => [\\n  { name: 'sessionHistoryOutput', type: DataType.JsonObj }\\n];\\n\\nconst onParentEvent = async ({ targetPort, event }) => {\\n  const inputData = event.data.value;\\n\\n  if (targetPort.name === 'read') {\\n    const sessionId = inputData.sessionId;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'read' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    await setOutput({ port: 'sessionHistoryOutput', data: { type: DataType.JsonObj, value: sessions[sessionId] } });\\n\\n  } else if (targetPort.name === 'update') {\\n    const sessionId = inputData.sessionId;\\n    const messagesToProcess = inputData.messages;\\n\\n    if (sessionId === undefined || sessionId === null) {\\n      console.error(\\\"Error: 'update' event missing 'sessionId' property.\\\");\\n      return;\\n    }\\n    if (messagesToProcess === undefined || messagesToProcess === null) {\\n      console.error(\\\"Error: 'update' event missing 'messagesToAdd' property. No messages to add.\\\");\\n      return;\\n    }\\n\\n    if (!sessions[sessionId]) {\\n      sessions[sessionId] = { messages: [] };\\n    }\\n\\n    if (Array.isArray(messagesToProcess)) {\\n      sessions[sessionId].messages.push(...messagesToProcess);\\n    } else {\\n      sessions[sessionId].messages.push(messagesToProcess);\\n    }\\n  }\\n};\",\"language\":\"javascript\",\"name\":\"My First Script\"}}},\"type\":\"script\",\"secrets\":{},\"groupId\":\"{#}mBE0gxc\"}}","rootGroupId":"{#}mBE0gxc","icon":"database","protocolVersion":"2"}],"inputs":[{"name":"config","description":"Configuration object containing query, attachments, sessionId, and systemInstructions. Can also be a string to be used as query or a boolean to trigger processing.","type":[5,4,1,6]},{"name":"abort","description":"Abort current query signal","type":6}],"outputs":[{"name":"tools","type":5},{"name":"history","type":5},{"name":"json","type":5},{"name":"text","type":1},{"name":"stream","type":1},{"name":"reasoning","description":"Reasoning output from models that support extended thinking","type":1},{"name":"images","description":"Generated images as ImageData array","type":3},{"name":"debug","description":"Includes debugging information for when things go wrong, including stopping reason","type":5}],"supportedPlatforms":["win-x86","win-x64","osx-x64","osx-arm64","linux-debian-arm64","linux-debian-x64","linux-rhel-arm64","linux-rhel-x64"],"author":"0f998d5a-a8ce-4bf8-9f84-fa8c481cb40b","defaultVariantInfo":{"title":"Agent","shortTitle":"Agent","description":"AI agent that processes queries with system instructions and attachments"},"variants":[{"id":"chatInterface","name":"Chat Interface","description":"Chat window UI that can invoke an Agent and display live outputs","svgIcon":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<svg width=\"1200pt\" height=\"1200pt\" version=\"1.1\" viewBox=\"0 0 1200 1200\" xmlns=\"http://www.w3.org/2000/svg\">\n <path d=\"m1034.4 486-298.78-46.781v244.78c0 26.391-10.781 50.391-31.219 67.219-15.609 14.391-36 21.609-57.609 21.609-4.7812 0-9.6094 0-14.391-1.2188l-134.39-20.391v80.391c0 15.609 7.2188 30 18 39.609 12 10.781 27.609 14.391 43.219 12l309.61-48h8.4375c1.2188 0 1.2188 1.2188 2.3906 1.2188 1.2188 1.2188 2.3906 1.2188 3.6094 2.3906l111.61 96-4.7812-103.22v-4.8281c0-1.2188 1.2188-3.6094 2.3906-4.7812 0-1.2188 0-1.2188 1.2188-1.2188 1.2188-1.2188 1.2188-1.2188 2.3906-2.3906 1.2188 0 1.2188-1.2188 2.3906-1.2188 1.2188 0 1.2188-1.2188 3.6094-1.2188 1.2188 0 1.2188-1.2188 2.3906-1.2188l28.781-4.7812c26.391-3.6094 45.609-26.391 45.609-52.781l-0.09375-217.18c1.2188-26.391-18-49.219-44.391-54z\"/>\n <path d=\"m681.61 724.78c12-9.6094 18-25.219 18-39.609v-367.18c0-15.609-7.2188-30-18-40.781-12-9.6094-27.609-14.391-43.219-12l-474 74.391c-26.391 4.7812-45.609 26.391-45.609 52.781v217.22c0 26.391 19.219 49.219 45.609 52.781l28.781 4.7812c1.2188 0 1.2188 1.2188 2.3906 1.2188 1.2188 0 2.3906 1.2188 3.6094 1.2188 1.21